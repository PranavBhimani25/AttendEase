            <div class="illustration-wrap">
                <svg viewBox="0 0 480 380" fill="none" xmlns="http://www.w3.org/2000/svg" class="hero-svg">
                    <circle cx="240" cy="190" r="160" fill="white" fill-opacity="0.06"/>
