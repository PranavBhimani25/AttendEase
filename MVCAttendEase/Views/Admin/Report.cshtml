@{
    ViewData["Title"] = "Employee Attendance Report";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-title">
    Employee List
</div>


<div class="task-container">
    <div id="employeeGrid"></div>
</div>


<div id="notification"></div>

<div id="employeeDetailWindow" style="display:none;">
    <div id="employeeDetailContent"></div>
</div>
<div id="monthPickerWindow" style="display:none;">
    <div id="monthPickerContent"></div>
</div>
<div id="monthlyReportWindow" style="display:none;">
    <div id="monthlyReportContent"></div>
</div>


@section Scripts{

<style>

.page-title{
    font-size:36px;
    font-weight:600;
    margin-bottom:20px;
}







/* HEADER */

.k-card-header{
    font-weight:600;
    font-size:18px;
    border-bottom:1px solid #eee;
}

/* ICON */

.stat-icon{
    font-size:35px;
    margin-top:15px;
    color:#2b7cff;
}
.stat-icon .k-icon{
    font-size:40px;
    color:#2b7cff;
}

/* NUMBER */

.stat-number{
    font-size:40px;
    font-weight:bold;
    margin-top:10px;
    color:#2b7cff;
}

/* TASK GRID */

.section-title{
    font-size:30px;
    font-weight:600;
    margin-top:40px;
    margin-bottom:15px;
}

.task-container{
    background:white;
    padding:25px;
    border-radius:12px;
    box-shadow:0 10px 20px rgba(0,0,0,0.1);
}

.report-filter-wrap{
    display:grid;
    gap:14px;
    padding:4px;
}

.report-filter-actions{
    display:flex;
    justify-content:flex-end;
    gap:10px;
}

.report-shell{
    display:grid;
    gap:20px;
    padding:6px;
}

.report-cards{
    display:grid;
    grid-template-columns:repeat(5, minmax(0, 1fr));
    gap:12px;
}

.report-card{
    background:#fff;
    border:1px solid #e7ebef;
    border-radius:10px;
    padding:12px;
}

.report-card-title{
    font-size:13px;
    color:#6c757d;
    margin-bottom:6px;
    min-height:36px;
}

.report-card-value{
    font-size:24px;
    font-weight:700;
    color:#2b7cff;
}

.report-charts{
    display:grid;
    grid-template-columns:1fr 1fr;
    gap:16px;
}

.report-chart-box{
    background:#fff;
    border:1px solid #e7ebef;
    border-radius:10px;
    padding:10px;
}

.chart-mode-wrap{
    display:flex;
    justify-content:flex-end;
    margin-bottom:8px;
}

.report-actions{
    display:flex;
    justify-content:flex-end;
    margin-top:10px;
}

</style>


<script>

var selectedReportEmployeeId = 0;
var selectedReportEmployeeName = "";
var currentReportMeta = { empId: 0, empName: "", month: 0, year: 0 };

$(document).ready(function(){

    $("#notification").kendoNotification({
        position:{
            pinned:true,
            top:30,
            right:30
        },
        autoHideAfter:2000,
        stacking:"down"
    });

    initDetailWindow();
    initMonthPickerWindow();
    initMonthlyReportWindow();
    createEmployeeGrid(); 
    bindGridActions();

});


/* CREATE GRID */

function createEmployeeGrid(){

    $("#employeeGrid").kendoGrid({

        columns:[

            { field:"empId", title:"Employee ID", width:"120px" },
            { field:"name", title:"Name" },
            
          
            {
                title:"Action",
                template:`
                    <div style="display:flex; gap:8px;">
                        <button class="k-button k-button-md k-button-outline k-button-outline-primary detail-btn" data-empid="#: empId #">
                            Detail
                        </button>
                        <button class="k-button k-button-md k-button-solid-primary report-btn" data-empid="#: empId #">
                            Report
                        </button>
                    </div>`,

                width:"240px"
            }

        ],

        dataSource:{
            transport:{
                read:{
                    url:"/Admin/GetEmployees",
                    dataType:"json"
                }
            },
            pageSize:10
        },

        pageable:{
            pageSizes:[10,20,50,100],
            buttonCount:5
        },
        sortable:true,
        filterable:true

    });

}

function initDetailWindow(){
    $("#employeeDetailWindow").kendoWindow({
        width: "520px",
        title: "Employee Details",
        visible: false,
        modal: true,
        resizable: false,
        actions: ["Close"]
    });
}

function bindGridActions(){
    $("#employeeGrid").on("click", ".detail-btn", function(){
        var empId = $(this).data("empid");
        showEmployeeDetails(empId);
    });

    $("#employeeGrid").on("click", ".report-btn", function(){
        var grid = $("#employeeGrid").data("kendoGrid");
        var row = $(this).closest("tr");
        var dataItem = grid.dataItem(row);

        selectedReportEmployeeId = dataItem.empId;
        selectedReportEmployeeName = dataItem.name || "";
        openMonthPickerWindow();
    });
}

function showEmployeeDetails(empId){
    var windowRef = $("#employeeDetailWindow").data("kendoWindow");
    var contentRef = $("#employeeDetailContent");

    contentRef.html("<p>Loading employee details...</p>");
    windowRef.center().open();

    $.ajax({
        url: "/Admin/GetEmployeeDetails",
        type: "GET",
        data: { empId: empId },
        success: function(emp){
            var imageHtml = emp.profileImage
                ? `<img src="${emp.profileImage}" alt="Profile" style="width:96px;height:96px;border-radius:50%;object-fit:cover;border:1px solid #ddd;" />`
                : `<div style="width:96px;height:96px;border-radius:50%;background:#f1f3f5;display:flex;align-items:center;justify-content:center;color:#6c757d;font-weight:600;">N/A</div>`;

            var detailsHtml = `
                <div style="display:flex;gap:16px;align-items:flex-start;">
                    ${imageHtml}
                    <div style="display:grid;gap:8px;">
                        <div><strong>Employee ID:</strong> ${emp.empId}</div>
                        <div><strong>Name:</strong> ${emp.name || "-"}</div>
                        <div><strong>Email:</strong> ${emp.email || "-"}</div>
                        <div><strong>Gender:</strong> ${emp.gender || "-"}</div>
                        <div><strong>Status:</strong> ${emp.status || "-"}</div>
                    </div>
                </div>`;

            contentRef.html(detailsHtml);
            windowRef.title(`Employee Details - ${emp.empId}`);
        },
        error: function(xhr){
            var msg = "Unable to load employee details.";
            if (xhr.responseJSON && xhr.responseJSON.message) {
                msg = xhr.responseJSON.message;
            }

            contentRef.html(`<p style="color:#d9534f;">${msg}</p>`);
            $("#notification").data("kendoNotification").show({ message: msg }, "error");
        }
    });
}

function initMonthPickerWindow(){
    $("#monthPickerWindow").kendoWindow({
        width: "420px",
        title: "Generate Monthly Report",
        visible: false,
        modal: true,
        resizable: false,
        actions: ["Close"]
    });
}

function initMonthlyReportWindow(){
    $("#monthlyReportWindow").kendoWindow({
        width: "1200px",
        height: "760px",
        title: "Monthly Report",
        visible: false,
        modal: true,
        resizable: true,
        actions: ["Maximize", "Close"]
    });
}

function openMonthPickerWindow(){
    var wnd = $("#monthPickerWindow").data("kendoWindow");

    var html = `
        <div class="report-filter-wrap">
            <label for="reportMonthPicker"><strong>Select Month and Year</strong></label>
            <input id="reportMonthPicker" style="width:100%;" />
            <div class="report-filter-actions">
                <button id="cancelReportBtn" class="k-button k-button-md k-button-outline k-button-outline-base">Cancel</button>
                <button id="generateReportBtn" class="k-button k-button-md k-button-solid-primary">Generate</button>
            </div>
        </div>`;

    $("#monthPickerContent").html(html);
    $("#reportMonthPicker").kendoDatePicker({
        start: "year",
        depth: "year",
        format: "MMMM yyyy",
        value: new Date()
    });

    wnd.center().open();
}

$(document).on("click", "#cancelReportBtn", function(){
    $("#monthPickerWindow").data("kendoWindow").close();
});

$(document).on("click", "#generateReportBtn", function(){
    var picker = $("#reportMonthPicker").data("kendoDatePicker");
    var selectedDate = picker ? picker.value() : null;

    if (!selectedDate) {
        $("#notification").data("kendoNotification").show({ message: "Please select month and year." }, "error");
        return;
    }

    var month = selectedDate.getMonth() + 1;
    var year = selectedDate.getFullYear();

    $("#monthPickerWindow").data("kendoWindow").close();
    generateMonthlyReportWindow(selectedReportEmployeeId, selectedReportEmployeeName, month, year);
});

$(document).on("click", "#downloadPdfBtn", function(){
    downloadCurrentReportPdf();
});

function generateMonthlyReportWindow(empId, empName, month, year){
    var reportWnd = $("#monthlyReportWindow").data("kendoWindow");
    currentReportMeta = { empId: empId, empName: empName || "", month: month, year: year };

    var shellHtml = `
        <div class="report-shell">
            <div id="reportCards" class="report-cards"></div>
            <div class="report-charts">
                <div class="report-chart-box"><div id="attendancePieChart"></div></div>
                <div class="report-chart-box">
                    <div class="chart-mode-wrap">
                        <input id="workingHourChartMode" style="width:220px;" />
                    </div>
                    <div id="dailyHourBarChart"></div>
                </div>
            </div>
            <div>
                <div id="monthlyReportGrid"></div>
                <div class="report-actions">
                    <button id="downloadPdfBtn" class="k-button k-button-md k-button-solid-primary">Download PDF</button>
                    <button id="sendPdfBtn" class="k-button k-button-md k-button-solid-primary">Send Pdf</button>
                </div>
            </div>
        </div>`;

    $("#monthlyReportContent").html(shellHtml);
    reportWnd.title(`Monthly Report - ${empName} (${month}/${year})`);
    reportWnd.center().open();

    $.ajax({
        url: "/Admin/GetEmployeeMonthlyReportData",
        type: "GET",
        data: { empId: empId, month: month, year: year },
        success: function(response){
            var summary = response.summary || response.Summary || {};
            var dailyHours = response.dailyHours || response.DailyHours || [];
            var yearlyWorkingHours = response.yearlyWorkingHours || response.YearlyWorkingHours || [];
            var attendanceDetails = response.attendanceDetails || response.AttendanceDetails || [];

            renderReportCards(summary);
            renderAttendancePieChart(summary);
            initializeWorkingHourChartModes(dailyHours, yearlyWorkingHours, month, year);
            renderMonthlyGrid(normalizeAttendanceRows(attendanceDetails));
        },
        error: function(xhr){
            var msg = "Unable to generate report.";
            if (xhr.responseJSON && xhr.responseJSON.message) {
                msg = xhr.responseJSON.message;
            }
            $("#monthlyReportContent").html(`<p style="color:#d9534f;">${msg}</p>`);
            $("#notification").data("kendoNotification").show({ message: msg }, "error");
        }
    });
}

function normalizeAttendanceRows(rows){
    return (rows || []).map(function(r){
        return {
            attendDate: r.attendDate || r.AttendDate || null,
            workType: r.workType || r.WorkType || "",
            taskType: r.taskType || r.TaskType || "",
            workingHours: r.workingHours ?? r.WorkingHours ?? 0,
            attendStatus: r.attendStatus || r.AttendStatus || ""
        };
    });
}

function renderReportCards(summary){
    var cards = [
        { title: "Total Working Hours In Month", value: summary.totalWorkingHours ?? 0 },
        { title: "Total Present Days In Month", value: summary.presentDays ?? 0 },
        { title: "Absent Days", value: summary.absentDays ?? 0 },
        { title: "Late In", value: summary.lateInDays ?? 0 },
        { title: "Early Out", value: summary.earlyOutDays ?? 0 }
    ];

    var html = cards.map(function(c){
        return `
            <div class="report-card k-card">
                <div class="report-card-title">${c.title}</div>
                <div class="report-card-value">${c.value}</div>
            </div>`;
    }).join("");

    $("#reportCards").html(html);
}

function renderAttendancePieChart(summary){
    $("#attendancePieChart").kendoChart({
        title: { text: "Attendance Split" },
        legend: { position: "bottom" },
        series: [{
            type: "pie",
            data: [
                { category: "Absent", value: summary.absentDays ?? 0, color: "#dc3545" },
                { category: "Late In", value: summary.lateInDays ?? 0, color: "#ffc107" },
                { category: "Early Out", value: summary.earlyOutDays ?? 0, color: "#fd7e14" },
                { category: "Regular", value: summary.regularDays ?? 0, color: "#0d6efd" }
            ],
            field: "value",
            categoryField: "category",
            labels: { visible: true, format: "{0}" }
        }],
        tooltip: { visible: true, template: "#= category #: #= value #" }
    });
}

function initializeWorkingHourChartModes(dailyHours, yearlyWorkingHours, month, year){
    $("#workingHourChartMode").kendoDropDownList({
        dataTextField: "text",
        dataValueField: "value",
        value: "monthly",
        dataSource: [
            { text: "Monthly working hours", value: "monthly" },
            { text: "Yearly working hours", value: "yearly" }
        ],
        change: function(){
            renderWorkingHourChartByMode(this.value(), dailyHours, yearlyWorkingHours, month, year);
        }
    });

    renderWorkingHourChartByMode("monthly", dailyHours, yearlyWorkingHours, month, year);
}

function renderWorkingHourChartByMode(mode, dailyHours, yearlyWorkingHours, month, year){
    if (mode === "yearly") {
        renderYearlyHourBarChart(yearlyWorkingHours, year);
        return;
    }

    renderDailyHourBarChart(dailyHours, month, year);
}

function renderDailyHourBarChart(dailyHours, month, year){
    var dayHours = {};
    (dailyHours || []).forEach(function(x){
        var dayNo = Number(x.day);
        dayHours[dayNo] = Number(x.workingHours || 0);
    });

    var daysInMonth = new Date(year, month, 0).getDate();
    var data = [];

    for (var day = 1; day <= daysInMonth; day++) {
        var dt = new Date(year, month - 1, day);
        var dow = dt.getDay();
        if (dow !== 0 && dow !== 6) {
            data.push({
                dayLabel: day.toString(),
                hours: Object.prototype.hasOwnProperty.call(dayHours, day) ? dayHours[day] : null
            });
        }
    }

    $("#dailyHourBarChart").kendoChart({
        title: { text: "Daily Working Hours" },
        legend: { visible: false },
        dataSource: { data: data },
        series: [{
            type: "column",
            field: "hours",
            categoryField: "dayLabel",
            color: "#2b7cff",
            missingValues: "gap",
            name: "Hours"
        }],
        categoryAxis: {
            title: { text: "Dates" },
            majorGridLines: { visible: false }
        },
        valueAxis: {
            title: { text: "Working Hours" },
            min: 0
        },
        tooltip: { visible: true, template: "Date #= category #: #= value # hrs" }
    });
}

function renderYearlyHourBarChart(yearlyWorkingHours, year){
    var monthNames = ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"];
    var hoursByMonth = {};

    (yearlyWorkingHours || []).forEach(function(x){
        var monthNo = Number(x.monthNo || x.MonthNo || 0);
        var hours = Number(x.workingHours || x.WorkingHours || 0);
        if (monthNo >= 1 && monthNo <= 12) {
            hoursByMonth[monthNo] = hours;
        }
    });

    var data = monthNames.map(function(name, idx){
        var monthNo = idx + 1;
        return {
            monthLabel: name,
            hours: Object.prototype.hasOwnProperty.call(hoursByMonth, monthNo) ? hoursByMonth[monthNo] : 0
        };
    });

    $("#dailyHourBarChart").kendoChart({
        title: { text: "Yearly Working Hours (" + year + ")" },
        legend: { visible: false },
        dataSource: { data: data },
        series: [{
            type: "column",
            field: "hours",
            categoryField: "monthLabel",
            color: "#2b7cff",
            name: "Hours"
        }],
        categoryAxis: {
            title: { text: "Months" },
            majorGridLines: { visible: false }
        },
        valueAxis: {
            title: { text: "Working Hours" },
            min: 0
        },
        tooltip: { visible: true, template: "#= category #: #= value # hrs" }
    });
}

function renderMonthlyGrid(rows){
    $("#monthlyReportGrid").kendoGrid({
        dataSource: {
            data: rows,
            pageSize: rows && rows.length ? rows.length : 1
        },
        scrollable: false,
        sortable: true,
        pageable: false,
        noRecords: {
            template: "No attendance records found for selected month."
        },
        columns: [
            { field: "attendDate", title: "Attend Date", template: "#= kendo.toString(kendo.parseDate(attendDate), 'dd-MMM-yyyy') #" },
            { field: "workType", title: "Work Type" },
            { field: "taskType", title: "Task Type" },
            { field: "workingHours", title: "Working Hours" },
            { field: "attendStatus", title: "Attend Status" }
        ]
    });
}

function downloadCurrentReportPdf(){
    var target = $("#monthlyReportContent .report-shell");
    if (!target.length) {
        $("#notification").data("kendoNotification").show({ message: "Report is not ready to download." }, "error");
        return;
    }

    var button = $("#downloadPdfBtn");
    var originalText = button.text();
    button.prop("disabled", true).text("Generating...");

    kendo.drawing.drawDOM(target, {
        paperSize: "A4",
        margin: "1cm",
        landscape: true,
        scale: 0.75,
        multiPage: true
    })
    .then(function(group){
        return kendo.drawing.exportPDF(group, {
            paperSize: "A4",
            margin: "1cm",
            landscape: true,
            multiPage: true
        });
    })
    .then(function(dataURI){
        var safeName = (currentReportMeta.empName || "Employee").replace(/[^a-zA-Z0-9_-]+/g, "_");
        var fileName = "AttendanceReport_" + safeName + "_" + currentReportMeta.month + "-" + currentReportMeta.year + ".pdf";

        // Reset button state before invoking browser save/preview flow.
        button.prop("disabled", false).text(originalText);

        kendo.saveAs({
            dataURI: dataURI,
            fileName: fileName
        });
    })
    .catch(function(){
        $("#notification").data("kendoNotification").show({ message: "Failed to generate PDF." }, "error");
    })
    .finally(function(){
        if (button.prop("disabled")) {
            button.prop("disabled", false).text(originalText);
        }
    });
}
$(document).on("click", "#sendPdfBtn", function(){
    sendNotification(selectedReportEmployeeId);
});

function sendNotification(selectedReportEmployeeId){
    console.log(selectedReportEmployeeId);
    $.ajax({
        url: "/Notification/SendNotificationAsync",
        type: "POST",
        data: {
            receiverName: selectedReportEmployeeId,
            message: "Your monthly attendance report is ready. Please check your email for the PDF report."
        },
        success: function(res){
            $("#notification").data("kendoNotification")
               .show("Notification sent successfully", "success");
                
        },
        error: function(){
            $("#notification").data("kendoNotification")
                .show({ message: "Failed to send notification" }, "error");
        }
    });
}


</script>

}
