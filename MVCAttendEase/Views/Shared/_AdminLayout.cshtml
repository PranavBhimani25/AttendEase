
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/kendo/kendo.common.min.css" />
    <link rel="stylesheet" href="~/lib/kendo/kendo.default-v2.min.css" />
    <link rel="stylesheet" href="~/lib/kendo/bootstrap-nordic.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body>

<div id="example">

    <!-- SIDEBAR -->
    <div id="sidebar">
        <div class="sidebar-header">
            <h4>Admin</h4>
        </div>

        <ul class="k-list-group">
            <li class="k-list-group-item">
                <span class="k-icon  k-i-home"></span>
                <a asp-controller="Admin" asp-action="Dashboard">Dashboard</a>
            </li>
            <li class="k-list-group-item">
                <span class="k-icon k-i-chart-line"></span>
                <a asp-controller="Admin" asp-action="Report">Report</a>
            </li>
            <li class="k-list-group-item">
                <span class="k-icon k-i-user"></span>
                <a asp-controller="Auth" asp-action="Logout">Logout</a>
            </li>
        </ul>
    </div>

    <!-- MAIN CONTENT -->
    <div id="main">

        <!-- TOP BAR -->
        <div class="topbar">
            <button id="sidebar-toggle" class="k-button k-button-md k-rounded-md">
                <span class="k-icon k-i-menu"></span>
            </button>
            <h4 class="ms-3">@ViewData["Title"]</h4>
        </div>

        <div class="content-wrapper">
            @RenderBody()
        </div>

    </div>

</div>

@* <footer class="footer text-muted">
    <div class="container">
        &copy; 2026 - MVCAttendEase
    </div>
</footer> *@

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/lib/kendo/kendo.all.min.js"></script>

<script>
$(document).ready(function () {
    $("#sidebar-toggle").click(function () {
        $("#sidebar").toggleClass("collapsed");
    });
});
</script>

<style>

/* Layout */
#example {
    display: flex;
    min-height: 100vh;
}

/* Sidebar */
#sidebar {
    width: 250px;
    background: #2c3e50;
    color: white;
    min-height: 100vh;
    transition: width 0.3s ease;
    overflow: hidden;
    flex-shrink: 0;
}

#sidebar.collapsed {
    width: 60px;
}

.sidebar-header {
    padding: 20px;
    font-size: 20px;
    font-weight: bold;
    white-space: nowrap;
}

#sidebar.collapsed .sidebar-header h4 {
    display: none;
}

/* Sidebar items */
.k-list-group-item {
    padding: 15px 20px;
    border: none !important;
    background: none !important;
    white-space: nowrap;
    display: flex;
    align-items: center;
}

.k-list-group-item a {
    color: white;
    text-decoration: none;
    margin-left: 10px;
    transition: opacity 0.2s;
}

#sidebar.collapsed .k-list-group-item a {
    display: none;
}
#sidebar.collapsed {
    width: 0;
    padding: 0;
}

.k-list-group-item:hover {
    background: #34495e !important;
}

/* Icon color fix */
.k-list-group-item .k-icon {
    color: white;
    flex-shrink: 0;
}

/* Top bar */
.topbar {
    display: flex;
    align-items: center;
    padding: 15px;
    border-bottom: 1px solid #ddd;
}

/* Content */
#main {
    flex: 1;
    display: flex;
    flex-direction: column;
}

.content-wrapper {
    padding: 25px;
    flex: 1;
}

/* Footer */
.footer {
    text-align: center;
    padding: 10px;
}

</style>

@await RenderSectionAsync("Scripts", required: false)

</body>
</html>