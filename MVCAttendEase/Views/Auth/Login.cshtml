                    <rect x="100" y="70" width="280" height="50" rx="20" fill="white" fill-opacity="0.15"/>
                    <rect x="100" y="100" width="280" height="20" fill="white" fill-opacity="0.08"/>
                    <circle cx="125" cy="95" r="6" fill="#FF6B9D"/>
                    <circle cx="147" cy="95" r="6" fill="#FFD93D"/>
                    <circle cx="169" cy="95" r="6" fill="#6BCB77"/>
                    <rect x="200" y="88" width="100" height="10" rx="5" fill="white" fill-opacity="0.4"/>
                    <rect x="120" y="138" width="55" height="38" rx="10" fill="white" fill-opacity="0.2"/>
                    <rect x="185" y="138" width="55" height="38" rx="10" fill="#A78BFA" fill-opacity="0.7"/>
                    <rect x="250" y="138" width="55" height="38" rx="10" fill="white" fill-opacity="0.2"/>
                    <rect x="315" y="138" width="55" height="38" rx="10" fill="white" fill-opacity="0.2"/>
                    <rect x="120" y="186" width="55" height="38" rx="10" fill="white" fill-opacity="0.2"/>
                    <rect x="185" y="186" width="55" height="38" rx="10" fill="white" fill-opacity="0.2"/>
                    <rect x="250" y="186" width="55" height="38" rx="10" fill="#6EE7B7" fill-opacity="0.6"/>
                    <rect x="315" y="186" width="55" height="38" rx="10" fill="white" fill-opacity="0.2"/>
                    <rect x="130" y="150" width="35" height="5" rx="2.5" fill="white" fill-opacity="0.5"/>
                    <rect x="130" y="160" width="25" height="4" rx="2" fill="white" fill-opacity="0.3"/>
                    <rect x="195" y="150" width="35" height="5" rx="2.5" fill="white" fill-opacity="0.9"/>
                    <rect x="195" y="160" width="25" height="4" rx="2" fill="white" fill-opacity="0.6"/>
                    <rect x="260" y="150" width="35" height="5" rx="2.5" fill="white" fill-opacity="0.5"/>
                    <rect x="260" y="160" width="25" height="4" rx="2" fill="white" fill-opacity="0.3"/>
                    <rect x="325" y="150" width="35" height="5" rx="2.5" fill="white" fill-opacity="0.5"/>
                    <rect x="325" y="160" width="25" height="4" rx="2" fill="white" fill-opacity="0.3"/>
                    <circle cx="212" cy="157" r="8" fill="white" fill-opacity="0.3"/>
                    <path d="M208 157L211 160L216 153" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    <circle cx="277" cy="193" r="8" fill="white" fill-opacity="0.3"/>
                    <path d="M273 193L276 196L281 189" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    <rect x="310" y="40" width="120" height="55" rx="14" fill="white" fill-opacity="0.18"/>
                    <text x="322" y="63" fill="white" fill-opacity="0.6" font-size="10" font-family="sans-serif">Attendance</text>
                    <text x="322" y="83" fill="white" font-size="20" font-family="sans-serif" font-weight="bold">94%</text>
                    <circle cx="415" cy="60" r="10" fill="#6EE7B7" fill-opacity="0.7"/>
