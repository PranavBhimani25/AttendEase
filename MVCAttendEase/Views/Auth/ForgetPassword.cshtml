@{
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
    ViewData["Title"] = "Forgot Password";
}

<div class="auth-wrapper">

    <!-- ════════════ LEFT PANEL ════════════ -->
    <div class="auth-left">
        <div class="left-content">
            <div class="brand-logo">
                <div class="logo-icon">
                    <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
                        <rect width="28" height="28" rx="8" fill="white" fill-opacity="0.2"/>
                        <path d="M14 6L20 10V18L14 22L8 18V10L14 6Z" fill="white" stroke="white" stroke-width="1.5" stroke-linejoin="round"/>
                        <circle cx="14" cy="14" r="3" fill="white" fill-opacity="0.6"/>
                    </svg>
                </div>
                <span class="brand-name">AttendEase</span>
            </div>

            <div class="illustration-wrap">
                <!-- Password / Security themed SVG -->
                <svg viewBox="0 0 480 380" fill="none" xmlns="http://www.w3.org/2000/svg" class="hero-svg">
                    <!-- Background circles -->
                    <circle cx="240" cy="190" r="165" fill="white" fill-opacity="0.05"/>
                    <circle cx="240" cy="190" r="110" fill="white" fill-opacity="0.05"/>

                    <!-- Big lock body -->
                    <rect x="155" y="160" width="170" height="140" rx="22" fill="white" fill-opacity="0.18"/>
                    <rect x="155" y="160" width="170" height="140" rx="22" stroke="white" stroke-opacity="0.25" stroke-width="1.5"/>

                    <!-- Lock shackle -->
                    <path d="M190 160 V128 C190 105 290 105 290 128 V160" stroke="white" stroke-opacity="0.5" stroke-width="14" stroke-linecap="round" fill="none"/>

                    <!-- Lock keyhole -->
                    <circle cx="240" cy="220" r="20" fill="white" fill-opacity="0.25"/>
                    <circle cx="240" cy="218" r="9" fill="white" fill-opacity="0.7"/>
                    <rect x="234" y="225" width="12" height="18" rx="4" fill="white" fill-opacity="0.7"/>

                    <!-- Decorative dots around lock -->
                    <circle cx="130" cy="150" r="7" fill="#A78BFA" fill-opacity="0.7"/>
                    <circle cx="350" cy="145" r="5" fill="#F472B6" fill-opacity="0.7"/>
                    <circle cx="115" cy="270" r="5" fill="#6EE7B7" fill-opacity="0.6"/>
                    <circle cx="365" cy="285" r="7" fill="#FFD93D" fill-opacity="0.6"/>
                    <circle cx="155" cy="330" r="4" fill="#A78BFA" fill-opacity="0.5"/>
                    <circle cx="330" cy="340" r="5" fill="#F472B6" fill-opacity="0.5"/>

                    <!-- Email envelope floating top-left -->
                    <rect x="58" y="90" width="120" height="80" rx="14" fill="white" fill-opacity="0.15"/>
                    <rect x="58" y="90" width="120" height="80" rx="14" stroke="white" stroke-opacity="0.2" stroke-width="1"/>
                    <!-- Envelope flap -->
                    <path d="M58 104 L118 138 L178 104" stroke="white" stroke-opacity="0.5" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
                    <rect x="78" y="116" width="80" height="7" rx="3.5" fill="white" fill-opacity="0.4"/>
                    <rect x="85" y="128" width="65" height="6" rx="3" fill="white" fill-opacity="0.25"/>
                    <!-- Green check badge on envelope -->
                    <circle cx="175" cy="90" r="14" fill="#10B981"/>
                    <path d="M169 90L173 94L181 85" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>

                    <!-- OTP code card floating top-right -->
                    <rect x="302" y="80" width="130" height="68" rx="14" fill="white" fill-opacity="0.18"/>
                    <rect x="302" y="80" width="130" height="68" rx="14" stroke="white" stroke-opacity="0.2" stroke-width="1"/>
                    <text x="317" y="106" fill="white" fill-opacity="0.5" font-size="10" font-family="sans-serif" font-weight="600">OTP CODE</text>
                    <!-- OTP boxes -->
                    <rect x="314" y="112" width="22" height="22" rx="6" fill="white" fill-opacity="0.3"/>
                    <rect x="342" y="112" width="22" height="22" rx="6" fill="#6366F1" fill-opacity="0.7"/>
                    <rect x="370" y="112" width="22" height="22" rx="6" fill="white" fill-opacity="0.3"/>
                    <rect x="398" y="112" width="22" height="22" rx="6" fill="white" fill-opacity="0.3"/>
                    <text x="320" y="128" fill="white" font-size="11" font-family="sans-serif" font-weight="700">3</text>
                    <text x="349" y="128" fill="white" font-size="11" font-family="sans-serif" font-weight="700">8</text>
                    <text x="376" y="128" fill="white" font-size="11" font-family="sans-serif" font-weight="700">5</text>
                    <text x="403" y="128" fill="white" font-size="11" font-family="sans-serif" font-weight="700">2</text>

                    <!-- Timer chip bottom -->
                    <rect x="175" y="318" width="130" height="36" rx="18" fill="white" fill-opacity="0.15"/>
                    <circle cx="198" cy="336" r="9" fill="#6366F1" fill-opacity="0.8"/>
                    <path d="M198 330 V336 L202 339" stroke="white" stroke-width="1.8" stroke-linecap="round"/>
                    <rect x="213" y="330" width="70" height="7" rx="3.5" fill="white" fill-opacity="0.6"/>
                    <rect x="218" y="341" width="55" height="6" rx="3" fill="white" fill-opacity="0.35"/>

                    <!-- Connection dashed lines -->
                    <line x1="178" y1="130" x2="200" y2="160" stroke="white" stroke-opacity="0.15" stroke-width="1" stroke-dasharray="4 4"/>
                    <line x1="302" y1="114" x2="290" y2="165" stroke="white" stroke-opacity="0.15" stroke-width="1" stroke-dasharray="4 4"/>
                </svg>
            </div>

            <div class="left-text">
                <h2>Reset Your Password Safely</h2>
                <p>We'll send a secure OTP to your registered email. Verify it and get back to managing attendance in seconds.</p>
            </div>

            <div class="feature-pills">
                <div class="pill"><span class="pill-dot green"></span>Secure OTP</div>
                <div class="pill"><span class="pill-dot purple"></span>60s expiry</div>
                <div class="pill"><span class="pill-dot pink"></span>Instant reset</div>
            </div>
        </div>
        <div class="blob blob-1"></div>
        <div class="blob blob-2"></div>
    </div>

    <!-- ════════════ RIGHT PANEL ════════════ -->
    <div class="auth-right">
        <div class="auth-card" id="fpCard">

            <!-- ── STEP 1: Email + Send OTP ── -->
            <div id="stepEmail">
                <div class="card-header">
                    <div class="avatar-ring">
                        <div class="avatar-inner">
                            <svg width="26" height="26" viewBox="0 0 26 26" fill="none">
                                <rect x="3" y="7" width="20" height="14" rx="4" stroke="#6366F1" stroke-width="2"/>
                                <path d="M3 10L13 16L23 10" stroke="#6366F1" stroke-width="2" stroke-linecap="round"/>
                            </svg>
                        </div>
                    </div>
                    <h1 class="card-title">Forgot Password?</h1>
                    <p class="card-subtitle">Enter your email and we'll send you a 6-digit OTP</p>
                </div>

                <form id="emailForm" novalidate autocomplete="off">
                    <div class="field-group">
                        <label class="field-label" for="fp_email">
                            <i class="fa fa-envelope lbl-icon"></i> Registered Email
                        </label>
                        <div class="input-wrap">
                            <i class="fa fa-envelope fi"></i>
                            <input id="fp_email" name="email" type="email" class="fi-input"
                                   placeholder="you@company.com" autocomplete="email"/>
                            <i class="fa fa-check vtick" id="tk_fp_email"></i>
                        </div>
                        <span class="err" id="e_fp_email"></span>
                    </div>

                    <button type="submit" class="btn-submit" id="sendOtpBtn">
                        <span class="btext"><i class="fa fa-paper-plane"></i>&nbsp; Send OTP</span>
                        <span class="bspinner"></span>
                    </button>
                </form>
            </div>

            <!-- ── STEP 2: OTP Verify (hidden initially) ── -->
            <div id="stepOtp" style="display:none;">
                <div class="card-header">
                    <div class="avatar-ring" style="background:linear-gradient(135deg,#10B981,#059669);">
                        <div class="avatar-inner">
                            <svg width="26" height="26" viewBox="0 0 26 26" fill="none">
                                <rect x="3" y="10" width="20" height="14" rx="4" stroke="#10B981" stroke-width="2"/>
                                <path d="M8 10V7C8 4.791 9.791 3 12 3H14C16.209 3 18 4.791 18 7V10" stroke="#10B981" stroke-width="2" stroke-linecap="round"/>
                                <circle cx="13" cy="17" r="2" fill="#10B981"/>
                            </svg>
                        </div>
                    </div>
                    <h1 class="card-title">Verify OTP</h1>
                    <p class="card-subtitle">
                        We sent a 6-digit code to<br/>
                        <strong id="emailDisplay" style="color:#6366F1;font-size:13px;"></strong>
                    </p>
                </div>

                <!-- OTP sent success banner -->
                <div class="otp-sent-banner">
                    <i class="fa fa-circle-check"></i>
                    OTP sent successfully! Check your inbox.
                </div>

                <form id="otpForm" novalidate autocomplete="off">

                    <!-- 4-box OTP input -->
                    <div class="field-group">
                        <label class="field-label">
                            <i class="fa fa-key lbl-icon"></i> Enter 6-Digit OTP
                        </label>
                        <div class="otp-boxes" id="otpBoxes">
                            <input class="otp-box" type="text" maxlength="1" inputmode="numeric" pattern="[0-9]"/>
                            <input class="otp-box" type="text" maxlength="1" inputmode="numeric" pattern="[0-9]"/>
                            <input class="otp-box" type="text" maxlength="1" inputmode="numeric" pattern="[0-9]"/>
                            <input class="otp-box" type="text" maxlength="1" inputmode="numeric" pattern="[0-9]"/>
                            <input class="otp-box" type="text" maxlength="1" inputmode="numeric" pattern="[0-9]"/>
                            <input class="otp-box" type="text" maxlength="1" inputmode="numeric" pattern="[0-9]"/>
                        </div>
                        <span class="err" id="e_otp"></span>
                    </div>

                    <!-- Timer row -->
                    <div class="timer-row">
                        <div class="timer-badge" id="timerBadge">
                            <i class="fa fa-clock"></i>
                            <span id="timerDisplay">60s remaining</span>
                        </div>
                        <button type="button" id="resendBtn" class="resend-btn" disabled>
                            <i class="fa fa-rotate-right"></i> Resend OTP
                        </button>
                    </div>

                    <!-- Progress bar -->
                    <div class="timer-bar-wrap">
                        <div class="timer-bar" id="timerBar"></div>
                    </div>

                    <button type="submit" class="btn-submit btn-green" id="verifyOtpBtn">
                        <span class="btext"><i class="fa fa-shield-check"></i>&nbsp; Verify &amp; Reset Password</span>
                        <span class="bspinner"></span>
                    </button>

                    <div class="back-link">
                        <button type="button" id="changeEmailBtn" class="link-back">
                            <i class="fa fa-arrow-left"></i> Change Email Address
                        </button>
                    </div>
                </form>
            </div>

            <!-- ── STEP 3: Success (hidden initially) ── -->
            <div id="stepSuccess" style="display:none;">
                <div class="success-wrap">
                    <div class="success-icon">
                        <i class="fa fa-check"></i>
                    </div>
                    <h2 class="success-title">Password Reset!</h2>
                    <p class="success-sub">
                        Your new password has been sent to your email address. Please check your inbox and login with your new credentials.
                    </p>
                    <div class="success-email-chip" id="successEmailChip"></div>
                    <a href="/Auth/Login" class="btn-submit" style="text-decoration:none;margin-top:8px;">
                        <i class="fa fa-right-to-bracket"></i>&nbsp; Go to Login
                    </a>
                </div>
            </div>

            <div id="notification"></div>

            <!-- Footer link -->
            <div class="switch-auth" id="switchAuthLink">
                Remember your password?
                <a href="/Auth/Login" class="link-primary">Sign In →</a>
            </div>

        </div><!-- /.auth-card -->
    </div><!-- /.auth-right -->

</div><!-- /.auth-wrapper -->

@section Scripts {
<style>
/* ══════════════════════════════════════════
   RESET & BASE
══════════════════════════════════════════ */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: 'Poppins', sans-serif; overflow: hidden; }

/* ══════════════════════════════════════════
   LAYOUT
══════════════════════════════════════════ */
.auth-wrapper { display: flex; height: 100vh; width: 100vw; overflow: hidden; }

/* ══════════════════════════════════════════
   LEFT PANEL  (identical to Login/Register)
══════════════════════════════════════════ */
.auth-left {
    flex: 0 0 46%;
    background: linear-gradient(135deg, #1E1B4B 0%, #4F46E5 40%, #7C3AED 75%, #BE185D 100%);
    position: relative; overflow: hidden;
    display: flex; align-items: center; justify-content: center;
    padding: 44px 40px;
}
.blob { position: absolute; border-radius: 50%; filter: blur(70px); opacity: .22; pointer-events: none; }
.blob-1 { width: 380px; height: 380px; background: #A78BFA; top: -80px; right: -60px;
    animation: bF 9s ease-in-out infinite alternate; }
.blob-2 { width: 280px; height: 280px; background: #EC4899; bottom: -60px; left: -50px;
    animation: bF 11s ease-in-out infinite alternate-reverse; }
@@keyframes bF {
    from { transform: translate(0,0) scale(1); }
    to   { transform: translate(18px,-18px) scale(1.06); }
}
.left-content {
    position: relative; z-index: 2;
    width: 100%; max-width: 390px;
    display: flex; flex-direction: column; align-items: flex-start; gap: 20px;
}
.brand-logo { display: flex; align-items: center; gap: 10px; }
.logo-icon {
    width: 40px; height: 40px; background: rgba(255,255,255,.15);
    border-radius: 10px; display: flex; align-items: center; justify-content: center;
    backdrop-filter: blur(8px); border: 1px solid rgba(255,255,255,.2);
}
.brand-name { color: #fff; font-size: 20px; font-weight: 700; letter-spacing: .5px; }
.illustration-wrap { width: 100%; animation: fU 7s ease-in-out infinite alternate; }
.hero-svg { width: 100%; height: auto; }
@@keyframes fU { from { transform: translateY(0); } to { transform: translateY(-12px); } }
.left-text h2 { color: #fff; font-size: 20px; font-weight: 700; line-height: 1.35; margin-bottom: 6px; }
.left-text p  { color: rgba(255,255,255,.65); font-size: 13.5px; line-height: 1.75; }
.feature-pills { display: flex; gap: 8px; flex-wrap: wrap; }
.pill {
    display: flex; align-items: center; gap: 7px;
    background: rgba(255,255,255,.12); border: 1px solid rgba(255,255,255,.15);
    backdrop-filter: blur(8px); border-radius: 20px;
    padding: 6px 13px; color: #fff; font-size: 12px; font-weight: 500;
}
.pill-dot { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; }
.pill-dot.green  { background: #6EE7B7; }
.pill-dot.purple { background: #A78BFA; }
.pill-dot.pink   { background: #F472B6; }

/* ══════════════════════════════════════════
   RIGHT PANEL
══════════════════════════════════════════ */
.auth-right {
    flex: 1; background: #F1F5F9;
    display: flex; align-items: center; justify-content: center;
    padding: 40px 24px; position: relative; overflow-y: auto;
}
.auth-right::before {
    content: ''; position: absolute; inset: 0; pointer-events: none;
    background: radial-gradient(ellipse at 70% 15%, rgba(99,102,241,.08) 0%, transparent 55%),
                radial-gradient(ellipse at 20% 85%, rgba(139,92,246,.06) 0%, transparent 55%);
}

/* ══════════════════════════════════════════
   CARD
══════════════════════════════════════════ */
.auth-card {
    width: 100%; max-width: 420px;
    background: #fff; border-radius: 24px;
    padding: 38px 36px 32px;
    box-shadow: 0 4px 6px -1px rgba(0,0,0,.05), 0 20px 60px -10px rgba(99,102,241,.15);
    border: 1px solid rgba(99,102,241,.08);
    animation: cIn .55s cubic-bezier(.16,1,.3,1) both;
    transition: box-shadow .3s, transform .3s;
    position: relative;
}
@@keyframes cIn {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
}
.auth-card:hover {
    box-shadow: 0 4px 6px -1px rgba(0,0,0,.05), 0 28px 70px -8px rgba(99,102,241,.2);
    transform: translateY(-2px);
}

/* ══════════════════════════════════════════
   CARD HEADER  (identical to Login/Register)
══════════════════════════════════════════ */
.card-header { text-align: center; margin-bottom: 26px; }
.avatar-ring {
    width: 66px; height: 66px; border-radius: 50%;
    background: linear-gradient(135deg, #6366F1, #8B5CF6);
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 16px;
    box-shadow: 0 8px 25px rgba(99,102,241,.35);
    position: relative; transition: background .4s;
}
.avatar-ring::before {
    content: ''; position: absolute; inset: -3px; border-radius: 50%;
    background: linear-gradient(135deg, #6366F1, #8B5CF6);
    opacity: .15; animation: pR 2.5s ease-in-out infinite;
}
@@keyframes pR {
    0%,100% { transform: scale(1); opacity: .15; }
    50%      { transform: scale(1.12); opacity: .05; }
}
.avatar-inner {
    width: 56px; height: 56px; border-radius: 50%;
    background: #fff; display: flex; align-items: center; justify-content: center;
}
.card-title    { font-size: 22px; font-weight: 700; color: #0F172A; margin-bottom: 5px; letter-spacing: -.3px; }
.card-subtitle { font-size: 13px; color: #94A3B8; line-height: 1.6; }

/* ══════════════════════════════════════════
   FORMS
══════════════════════════════════════════ */
#emailForm, #otpForm {
    display: flex; flex-direction: column; gap: 16px; width: 100%;
}

/* ══════════════════════════════════════════
   FIELD GROUP  (identical to Login/Register)
══════════════════════════════════════════ */
.field-group { display: flex; flex-direction: column; gap: 5px; }
.field-label {
    font-size: 11.5px; font-weight: 600; color: #475569;
    display: flex; align-items: center; gap: 5px; letter-spacing: .1px;
}
.lbl-icon { color: #6366F1; font-size: 10.5px; }

/* ══════════════════════════════════════════
   INPUT WRAP  (identical to Login/Register)
══════════════════════════════════════════ */
.input-wrap { position: relative; display: flex; align-items: center; width: 100%; }
.fi {
    position: absolute; left: 13px; color: #CBD5E1; font-size: 13px;
    pointer-events: none; z-index: 2; transition: color .2s;
}
.input-wrap:focus-within .fi { color: #6366F1; }
.fi-input {
    width: 100%; height: 48px;
    padding: 0 42px 0 40px;
    border: 1.5px solid #E2E8F0; border-radius: 12px;
    background: #F8FAFC;
    font-family: 'Poppins', sans-serif; font-size: 13.5px; color: #0F172A;
    outline: none;
    transition: border-color .2s, box-shadow .2s, background .2s;
}
.fi-input::placeholder { color: #C8D3E0; font-size: 13px; }
.fi-input:focus {
    border-color: #6366F1; background: #fff;
    box-shadow: 0 0 0 3px rgba(99,102,241,.12);
}
.fi-input.is-valid   { border-color: #10B981 !important; background: #fff; }
.fi-input.is-invalid {
    border-color: #EF4444 !important; background: #FFF5F5;
    box-shadow: 0 0 0 3px rgba(239,68,68,.08) !important;
}
.vtick {
    position: absolute; right: 13px; color: #10B981; font-size: 12px;
    opacity: 0; transition: opacity .2s; pointer-events: none;
}
.vtick.on { opacity: 1; }

/* ══════════════════════════════════════════
   ERROR MSG  (identical to Login/Register)
══════════════════════════════════════════ */
.err {
    font-size: 11px; color: #EF4444; font-weight: 500; min-height: 15px;
    display: flex; align-items: center; gap: 4px;
    animation: eIn .18s ease;
}
@@keyframes eIn { from { opacity:0; transform:translateY(-3px); } to { opacity:1; transform:translateY(0); } }

/* ══════════════════════════════════════════
   OTP SENT BANNER
══════════════════════════════════════════ */
.otp-sent-banner {
    display: flex; align-items: center; gap: 9px;
    background: linear-gradient(135deg, #ECFDF5, #D1FAE5);
    border: 1.5px solid #A7F3D0;
    border-radius: 12px; padding: 11px 16px;
    font-size: 12.5px; color: #065F46; font-weight: 600;
    margin-bottom: 4px;
    animation: eIn .3s ease;
}
.otp-sent-banner i { color: #10B981; font-size: 15px; flex-shrink: 0; }

/* ══════════════════════════════════════════
   OTP BOXES
══════════════════════════════════════════ */
.otp-boxes {
    display: flex; gap: 10px; justify-content: center; margin-top: 4px;
}
.otp-box {
    width: 52px; height: 58px;
    border: 2px solid #E2E8F0; border-radius: 14px;
    background: #F8FAFC;
    font-family: 'Poppins', sans-serif; font-size: 22px; font-weight: 700;
    color: #0F172A; text-align: center;
    outline: none; caret-color: #6366F1;
    transition: border-color .2s, box-shadow .2s, background .2s, transform .15s;
}
.otp-box:focus {
    border-color: #6366F1; background: #fff;
    box-shadow: 0 0 0 3px rgba(99,102,241,.14);
    transform: scale(1.06);
}
.otp-box.filled {
    border-color: #10B981; background: #ECFDF5; color: #10B981;
}
.otp-box.is-invalid {
    border-color: #EF4444 !important; background: #FFF5F5 !important;
    animation: shake .35s ease;
}
@@keyframes shake {
    0%,100% { transform: translateX(0); }
    25%      { transform: translateX(-5px); }
    75%      { transform: translateX(5px); }
}

/* ══════════════════════════════════════════
   TIMER
══════════════════════════════════════════ */
.timer-row {
    display: flex; align-items: center; justify-content: space-between;
    margin-top: -4px;
}
.timer-badge {
    display: flex; align-items: center; gap: 6px;
    background: rgba(99,102,241,.08);
    border: 1px solid rgba(99,102,241,.15);
    border-radius: 20px; padding: 5px 12px;
    font-size: 12px; color: #6366F1; font-weight: 600;
    transition: all .3s;
}
.timer-badge.expired {
    background: rgba(239,68,68,.07);
    border-color: rgba(239,68,68,.2);
    color: #EF4444;
}
.timer-bar-wrap {
    width: 100%; height: 4px; background: #F1F5F9;
    border-radius: 4px; overflow: hidden; margin-top: 2px;
}
.timer-bar {
    height: 100%; width: 100%; border-radius: 4px;
    background: linear-gradient(90deg, #6366F1, #8B5CF6);
    transition: width 1s linear, background .3s;
    transform-origin: left;
}
.timer-bar.low { background: linear-gradient(90deg, #F59E0B, #EF4444); }

.resend-btn {
    background: none; border: none; cursor: pointer;
    font-family: 'Poppins', sans-serif; font-size: 12px;
    color: #CBD5E1; font-weight: 600;
    display: flex; align-items: center; gap: 5px;
    padding: 4px 2px; transition: color .2s;
}
.resend-btn:not(:disabled) { color: #6366F1; }
.resend-btn:not(:disabled):hover { color: #4F46E5; }
.resend-btn:disabled { cursor: not-allowed; }

/* ══════════════════════════════════════════
   SUBMIT BUTTON  (identical to Login/Register)
══════════════════════════════════════════ */
.btn-submit {
    width: 100%; height: 50px;
    background: linear-gradient(135deg, #6366F1, #8B5CF6);
    color: #fff; border: none; border-radius: 14px;
    font-family: 'Poppins', sans-serif; font-size: 14.5px; font-weight: 600;
    cursor: pointer; letter-spacing: .4px;
    display: flex; align-items: center; justify-content: center; gap: 8px;
    transition: transform .2s, box-shadow .2s;
    box-shadow: 0 4px 15px rgba(99,102,241,.4);
    position: relative; overflow: hidden; margin-top: 4px;
}
.btn-submit::before {
    content: ''; position: absolute;
    top: 0; left: -100%; width: 100%; height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,.15), transparent);
    transition: left .5s;
}
.btn-submit:hover::before { left: 100%; }
.btn-submit:hover  { transform: translateY(-2px); box-shadow: 0 8px 25px rgba(99,102,241,.5); }
.btn-submit:active { transform: translateY(0); }
.btn-submit:disabled { opacity: .75; cursor: not-allowed; transform: none; }

/* Green variant for verify step */
.btn-green {
    background: linear-gradient(135deg, #10B981, #059669) !important;
    box-shadow: 0 4px 15px rgba(16,185,129,.4) !important;
}
.btn-green:hover { box-shadow: 0 8px 25px rgba(16,185,129,.5) !important; }

.bspinner {
    display: none; width: 18px; height: 18px;
    border: 2px solid rgba(255,255,255,.35);
    border-top-color: #fff; border-radius: 50%;
    animation: spin .7s linear infinite;
}
.btn-submit.loading .btext    { display: none; }
.btn-submit.loading .bspinner { display: block; }
@@keyframes spin { to { transform: rotate(360deg); } }

/* ══════════════════════════════════════════
   BACK LINK
══════════════════════════════════════════ */
.back-link { text-align: center; margin-top: 2px; }
.link-back {
    background: none; border: none; cursor: pointer;
    font-family: 'Poppins', sans-serif; font-size: 12.5px;
    color: #94A3B8; font-weight: 500;
    display: inline-flex; align-items: center; gap: 5px;
    transition: color .2s; padding: 0;
}
.link-back:hover { color: #6366F1; }

/* ══════════════════════════════════════════
   SUCCESS STATE
══════════════════════════════════════════ */
.success-wrap { text-align: center; padding: 8px 0; }
.success-icon {
    width: 76px; height: 76px; border-radius: 50%;
    background: linear-gradient(135deg, #10B981, #059669);
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 20px;
    box-shadow: 0 8px 30px rgba(16,185,129,.4);
    font-size: 30px; color: white;
    animation: successPop .5s cubic-bezier(.16,1,.3,1) both;
}
@@keyframes successPop {
    from { transform: scale(0.5); opacity: 0; }
    to   { transform: scale(1);   opacity: 1; }
}
.success-icon i {
    animation: checkDraw .4s .3s ease both;
}
@@keyframes checkDraw {
    from { opacity: 0; transform: scale(0.5) rotate(-20deg); }
    to   { opacity: 1; transform: scale(1)   rotate(0deg); }
}
.success-title {
    font-size: 22px; font-weight: 700; color: #0F172A;
    margin-bottom: 10px; letter-spacing: -.3px;
}
.success-sub {
    font-size: 13.5px; color: #64748B; line-height: 1.7;
    margin-bottom: 20px;
}
.success-email-chip {
    display: inline-flex; align-items: center; gap: 7px;
    background: rgba(99,102,241,.08); border: 1px solid rgba(99,102,241,.18);
    border-radius: 20px; padding: 6px 16px;
    font-size: 12.5px; color: #6366F1; font-weight: 600;
    margin-bottom: 20px;
}

/* ══════════════════════════════════════════
   SWITCH LINK  (identical to Login/Register)
══════════════════════════════════════════ */
.switch-auth { text-align: center; font-size: 13px; color: #64748B; margin-top: 16px; }
.link-primary { color: #6366F1; font-weight: 600; text-decoration: none; margin-left: 5px; transition: color .2s; }
.link-primary:hover { color: #4F46E5; }

/* ══════════════════════════════════════════
   KENDO NOTIFICATION
══════════════════════════════════════════ */
.k-notification-group { z-index: 9999 !important; }
.k-notification { border-radius: 12px !important; font-family: 'Poppins', sans-serif !important; font-size: 13px !important; }
.k-notification-success { background: #ECFDF5 !important; border-color: #A7F3D0 !important; color: #065F46 !important; }
.k-notification-error   { background: #FEF2F2 !important; border-color: #FECACA !important; color: #991B1B !important; }

/* ══════════════════════════════════════════
   STEP TRANSITION
══════════════════════════════════════════ */
.step-fade {
    animation: stepFade .4s cubic-bezier(.16,1,.3,1) both;
}
@@keyframes stepFade {
    from { opacity: 0; transform: translateX(20px); }
    to   { opacity: 1; transform: translateX(0); }
}

/* ══════════════════════════════════════════
   RESPONSIVE
══════════════════════════════════════════ */
@@media (max-width: 900px)  { .auth-left { display: none; } .auth-right { flex: 1; } }
@@media (max-width: 480px)  {
    .auth-card { padding: 28px 20px; border-radius: 18px; }
    .otp-box   { width: 44px; height: 52px; font-size: 20px; }
    .otp-boxes { gap: 7px; }
}
</style>

<script>
$(document).ready(function () {

    /* ── Kendo Notification ── */
    var notify = $("#notification").kendoNotification({
        position: { pinned: true, top: 24, right: 24 },
        autoHideAfter: 3000,
        animation: {
            open:  { effects: "slideIn:down fade:in", duration: 300 },
            close: { duration: 200 }
        }
    }).data("kendoNotification");

    function toast(msg, type) { notify.show(msg, type || "info"); }

    /* ═══════════════════════════════════════
       HELPERS
    ═══════════════════════════════════════ */
    function setErr(inputId, errId, tickId, msg) {
        $("#" + inputId).removeClass("is-valid").addClass("is-invalid");
        $("#" + errId).html('<i class="fa fa-exclamation-circle"></i>&nbsp;' + msg);
        if (tickId) { $("#" + tickId).removeClass("on"); }
    }
    function setOk(inputId, errId, tickId) {
        $("#" + inputId).removeClass("is-invalid").addClass("is-valid");
        $("#" + errId).text("");
        if (tickId) { $("#" + tickId).addClass("on"); }
    }

    /* ═══════════════════════════════════════
       STEP 1 — EMAIL VALIDATION
    ═══════════════════════════════════════ */
    var emailRe = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/;

    function validateEmail() {
        var v = $.trim($("#fp_email").val());
        if (!v)          { setErr("fp_email", "e_fp_email", "tk_fp_email", "Email address is required"); return false; }
        if (!emailRe.test(v)) { setErr("fp_email", "e_fp_email", "tk_fp_email", "Enter a valid email address"); return false; }
        setOk("fp_email", "e_fp_email", "tk_fp_email");
        return true;
    }

    $("#fp_email")
        .on("input", function () { if ($(this).val()) validateEmail(); })
        .on("blur",  validateEmail);

    /* ── Send OTP submit ── */
    $("#emailForm").on("submit", function (e) {
        e.preventDefault();
        if (!validateEmail()) {
            toast("Please enter a valid email address", "error");
            return;
        }

        var btn = $("#sendOtpBtn");
        btn.addClass("loading").prop("disabled", true);
        var email = $.trim($("#fp_email").val());

        $.ajax({
            url:    "/Auth/SendOtp",
            method: "POST",
            data:   { email: email },

            success: function (response) {
                btn.removeClass("loading").prop("disabled", false);
                if (response.success) {
                    /* Switch to OTP step */
                    $("#emailDisplay").text(email);
                    $("#successEmailChip").html('<i class="fa fa-envelope"></i>&nbsp;' + email);
                    showStep("stepOtp");
                    startTimer();
                    /* Focus first OTP box */
                    $(".otp-box").first().focus();
                } else {
                    toast(response.message || "Could not send OTP. Please try again.", "error");
                }
            },

            error: function (xhr) {
                btn.removeClass("loading").prop("disabled", false);
                var msg = (xhr.responseJSON && xhr.responseJSON.message)
                    ? xhr.responseJSON.message : "User not found. Please check your email.";
                toast(msg, "error");
                setErr("fp_email", "e_fp_email", "tk_fp_email", msg);
            }
        });
    });

    /* ═══════════════════════════════════════
       OTP BOX — auto-advance & backspace
    ═══════════════════════════════════════ */
    $(document).on("input", ".otp-box", function () {
        var val = $(this).val().replace(/\D/g, "");  /* digits only */
        $(this).val(val);

        if (val) {
            $(this).addClass("filled").removeClass("is-invalid");
            /* move to next */
            var next = $(this).nextAll(".otp-box:first");
            if (next.length) next.focus();
        } else {
            $(this).removeClass("filled");
        }
    });

    $(document).on("keydown", ".otp-box", function (e) {
        if (e.key === "Backspace" && !$(this).val()) {
            /* move to previous on empty backspace */
            $(this).prevAll(".otp-box:first").focus().val("").removeClass("filled");
        }
        /* Allow paste */
        if ((e.ctrlKey || e.metaKey) && e.key === "v") return true;
    });

    /* Handle paste of full OTP string */
    $(document).on("paste", ".otp-box", function (e) {
        e.preventDefault();
        var pasted = (e.originalEvent.clipboardData || window.clipboardData)
            .getData("text").replace(/\D/g, "").slice(0, 6);
        var boxes = $(".otp-box");
        boxes.each(function (i) {
            var ch = pasted[i] || "";
            $(this).val(ch);
            if (ch) $(this).addClass("filled"); else $(this).removeClass("filled");
        });
        boxes.last().focus();
    });

    function getOtpValue() {
        return $(".otp-box").map(function () { return $(this).val(); }).get().join("");
    }

    /* ── Verify OTP submit ── */
    $("#otpForm").on("submit", function (e) {
        e.preventDefault();
        var otp   = getOtpValue();
        var email = $.trim($("#fp_email").val());

        if (otp.length < 6) {
            $(".otp-box").addClass("is-invalid");
            $("#e_otp").html('<i class="fa fa-exclamation-circle"></i>&nbsp;Please enter all 6 digits');
            toast("Please enter the complete 6-digit OTP", "error");
            return;
        }

        var btn = $("#verifyOtpBtn");
        btn.addClass("loading").prop("disabled", true);

        $.ajax({
            url:    "/Auth/ForgetPassword",
            method: "POST",
            data:   { email: email, otp: otp },

            success: function (response) {
                btn.removeClass("loading").prop("disabled", false);
                if (response.success) {
                    clearInterval(timerInterval);
                    showStep("stepSuccess");
                } else {
                    $(".otp-box").addClass("is-invalid");
                    $("#e_otp").html('<i class="fa fa-exclamation-circle"></i>&nbsp;' + (response.message || "Invalid OTP. Please try again."));
                    toast(response.message || "Invalid OTP. Please try again.", "error");
                }
            },

            error: function (xhr) {
                btn.removeClass("loading").prop("disabled", false);
                var msg = (xhr.responseJSON && xhr.responseJSON.message)
                    ? xhr.responseJSON.message : "Verification failed. Try again.";
                $(".otp-box").addClass("is-invalid");
                $("#e_otp").html('<i class="fa fa-exclamation-circle"></i>&nbsp;' + msg);
                toast(msg, "error");
            }
        });
    });

    /* ═══════════════════════════════════════
       RESEND OTP
    ═══════════════════════════════════════ */
    $("#resendBtn").on("click", function () {
        var email = $.trim($("#fp_email").val());
        var self  = $(this);
        self.prop("disabled", true);

        $.ajax({
            url:    "/Auth/SendOtp",
            method: "POST",
            data:   { email: email },
            success: function (response) {
                if (response.success) {
                    /* Reset OTP boxes */
                    $(".otp-box").val("").removeClass("filled is-invalid");
                    $("#e_otp").text("");
                    $(".otp-box").first().focus();
                    startTimer();
                    toast("New OTP sent to " + email, "success");
                } else {
                    toast(response.message || "Failed to resend OTP", "error");
                    self.prop("disabled", false);
                }
            },
            error: function () {
                toast("Failed to resend OTP. Please try again.", "error");
                self.prop("disabled", false);
            }
        });
    });

    /* ── Change email ── */
    $("#changeEmailBtn").on("click", function () {
        clearInterval(timerInterval);
        $(".otp-box").val("").removeClass("filled is-invalid");
        $("#e_otp").text("");
        showStep("stepEmail");
        $("#fp_email").removeClass("is-valid is-invalid").focus();
        $("#e_fp_email").text("");
        $("#tk_fp_email").removeClass("on");
    });

    /* ═══════════════════════════════════════
       STEP SWITCHER (with fade animation)
    ═══════════════════════════════════════ */
    function showStep(stepId) {
        var steps = ["stepEmail", "stepOtp", "stepSuccess"];
        steps.forEach(function (id) {
            if (id === stepId) {
                $("#" + id).addClass("step-fade").show();
            } else {
                $("#" + id).hide().removeClass("step-fade");
            }
        });
        /* Hide footer link on success */
        if (stepId === "stepSuccess") {
            $("#switchAuthLink").hide();
        } else {
            $("#switchAuthLink").show();
        }
    }

    /* ═══════════════════════════════════════
       COUNTDOWN TIMER
    ═══════════════════════════════════════ */
    var timerInterval;
    var TIMER_TOTAL = 60;

    function startTimer() {
        clearInterval(timerInterval);
        var timeLeft = TIMER_TOTAL;

        /* Reset UI */
        $("#resendBtn").prop("disabled", true);
        $("#timerBadge").removeClass("expired");
        $("#timerBar").css({ width: "100%", background: "" }).removeClass("low");
        $("#timerDisplay").text(timeLeft + "s remaining");

        timerInterval = setInterval(function () {
            timeLeft--;
            var pct = (timeLeft / TIMER_TOTAL) * 100;

            /* Update display */
            $("#timerDisplay").text(timeLeft + "s remaining");
            $("#timerBar").css("width", pct + "%");

            /* Colour change in last 15s */
            if (timeLeft <= 15) {
                $("#timerBar").addClass("low");
                $("#timerBadge").addClass("expired");
                $("#timerDisplay").text(timeLeft + "s — OTP expiring!");
            }

            if (timeLeft <= 0) {
                clearInterval(timerInterval);
                $("#timerDisplay").text("OTP expired");
                $("#timerBar").css("width", "0%");
                $("#resendBtn").prop("disabled", false);
            }
        }, 1000);
    }

});
</script>
}
