}
.mb-name { font-size: 11.5px; font-weight: 500; flex: 1; color: var(--text-dark); }
.mb-status { font-size: 10px; padding: 2px 8px; border-radius: 6px; font-weight: 600; }
.mb-status.present { background: #ECFDF5; color: #065F46; }
.mb-status.late    { background: #FFFBEB; color: #92400E; }
.mb-status.absent  { background: #FEF2F2; color: #991B1B; }
.mb-time { font-size: 10px; color: var(--text-soft); }

/* ── TRUST STRIP ── */
.trust-strip {
    background: var(--surface); border-bottom: 1px solid var(--border);
    padding: 18px 0;
}
.trust-strip .lp-container { display: flex; align-items: center; gap: 24px; flex-wrap: wrap; }
.trust-label { font-size: 12px; font-weight: 600; color: var(--text-soft); white-space: nowrap; }
.trust-pills { display: flex; gap: 10px; flex-wrap: wrap; }
.trust-pill {
    display: flex; align-items: center; gap: 6px;
    background: #fff; border: 1px solid var(--border);
    border-radius: 100px; padding: 5px 13px;
    font-size: 12px; font-weight: 500; color: var(--text-mid);
}
.trust-pill i { color: var(--primary); font-size: 11px; }

/* ── SECTIONS ── */
.lp-section { padding: 90px 0; }
.lp-how { background: var(--surface); }

/* Section headers */
.sec-head { margin-bottom: 52px; }
.sec-head.text-center { text-align: center; }
.sec-label {
    display: inline-flex; align-items: center; gap: 8px;
