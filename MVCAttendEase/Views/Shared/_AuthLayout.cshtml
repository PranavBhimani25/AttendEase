<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - AttendEase</title>

    <!-- Bootstrap -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- Kendo -->
    <link rel="stylesheet" href="~/lib/kendo/bootstrap-nordic.css" />

    <!-- Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">

    <style>
        body {
            margin: 0;
            font-family: 'Poppins', sans-serif;
        }

        /* ===== MAIN SPLIT LAYOUT ===== */
        .login-wrapper {
            display: flex;
            height: 100vh;
        }

        /* LEFT SIDE */
        .login-left {
            flex: 1;
            background: linear-gradient(135deg, #1E3A8A, #3B82F6);
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .login-left img {
            width: 70%;
            max-width: 420px;
        }

        /* RIGHT SIDE */
        .login-right {
            flex: 1;
            background: #f8fafc;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        /* CARD */
        .login-card {
            width: 100%;
            max-width: 360px;
            text-align: center;
        }

        /* ICON */
        .user-icon {
            width: 70px;
            height: 70px;
            border-radius: 50%;
            background: #e2e8f0;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: auto;
            font-size: 24px;
            color: #334155;
        }

        /* TEXT */
        .welcome-text {
            margin: 20px 0;
            font-weight: 600;
            letter-spacing: 1px;
        }

        /* INPUT FIX */
        .k-textbox {
            border-radius: 25px !important;
            height: 45px;
        }

        /* BUTTON */
        .k-button.k-primary {
            border-radius: 25px !important;
            height: 45px;
            background: linear-gradient(to right, #1E3A8A, #60A5FA);
            border: none;
            font-weight: 600;
            transition: 0.3s;
        }

        .k-button.k-primary:hover {
            transform: scale(1.05);
        }

        /* LINKS */
        .forgot-text {
            text-align: right;
            margin-top: 5px;
        }

        .forgot-text a {
            font-size: 13px;
            color: #64748b;
        }

        .register-text {
            margin-top: 20px;
            font-size: 14px;
        }

        .register-text a {
            color: #2563eb;
            font-weight: 500;
        }

        /* RESPONSIVE */
        @@media (max-width: 768px) {
            .login-wrapper {
                flex-direction: column;
            }

            .login-left {
                height: 200px;
            }
        }
    </style>
</head>

<body>

    @RenderBody()

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/kendo/kendo.all.min.js"></script>

    @RenderSection("Scripts", required: false)

</body>
</html>