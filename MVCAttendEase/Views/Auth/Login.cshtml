@{
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
    ViewData["Title"] = "Login";
}

<div class="auth-title">
    AttendEase
</div>

<div class="auth-subtitle">
    Employee Attendance System
</div>

<form id="loginForm"></form>

<div class="auth-footer">
    Don't have an account?
    <a href="/Auth/Register">Register</a>
</div>

<div id="notification"></div>

@section Scripts{

    <script>

        $(document).ready(function () {

            // ── Kendo Notification setup ──────────────────────────────────────
            $("#notification").kendoNotification({
                position: {
                    pinned: true,
                    top: 30,
                    right: 30
                },
                autoHideAfter: 2000,
                stacking: "down",
                templates: [
                    {
                        type: "error",
                        template: "<div class='k-notification-error'>#: message #</div>"
                    }
                ]
            });

            // ── Kendo Form setup ──────────────────────────────────────────────
            $("#loginForm").kendoForm({

                formData: {
                    c_email: "",
                    c_password: ""
                },

                items: [
                    {
                        field: "email",
                        label: "Email",
                        validation: {
                            required: { message: "Email is required" },
                            email: { message: "Invalid email format" }
                        },
                        editor: function (container, options) {
                            $('<input required="required" name="' + options.field + '" type="email"/>')
                                .appendTo(container)
                                .kendoTextBox({ placeholder: "Enter your email" });
                        }
                    },
                    {
                        field: "password",
                        label: "Password",
                        validator: { required: { message: "Password is required" } },
                        editor: function (container, options) {
                            $('<input required="required" name="' + options.field + '" type="password"/>')
                                .appendTo(container)
                                .kendoTextBox({ placeholder: "Enter password" });
                        }
                    }
                ],

                buttonsTemplate: `
                    <button type="submit" class="k-button k-primary w-100">
                        Login
                    </button>
                `,

                submit: function (e) {
                    e.preventDefault();

                    var formdata = {
                        c_email: e.model.email,
                        c_password: e.model.password
                    };

                    // ── Show preloader when Login button is clicked ────────────
                    showPreloader("Logging in...", "Please wait while we verify your credentials");
                    // ─────────────────────────────────────────────────────────────

                    $.ajax({
                        url: "/Auth/Login",
                        method: "POST",
                        data: JSON.stringify(formdata),
                        contentType: "application/json",

                        success: function (response) {

                            if (response.success) {

                                // ── Update preloader message on success ───────────
                                showPreloader("Login Successful!", "Redirecting to your dashboard...");
                                // ─────────────────────────────────────────────────

                                $("#notification").data("kendoNotification").show("Login successful!", "success");

                                sessionStorage.setItem("userRole", response.role);
                                sessionStorage.setItem("userId", response.id);

                                // Redirect after short delay so user sees the success message
                                setTimeout(function () {
                                    if (response.role === "Admin") {
                                        window.location.href = "/Admin/Dashboard";
                                    } else {
                                        window.location.href = "/Employee/Dashboard";
                                    }
                                }, 1500);

                            } else {
                                // ── Hide preloader on failure ─────────────────────
                                hidePreloader();
                                // ─────────────────────────────────────────────────

                                $("#notification").data("kendoNotification")
                                    .show({ message: "Invalid credentials" }, "error");
                            }
                        },

                        error: function (xhr) {
                            // ── Hide preloader on error ───────────────────────────
                            hidePreloader();
                            // ─────────────────────────────────────────────────────

                            var message = "Login failed. Please try again.";
                            if (xhr.responseJSON && xhr.responseJSON.message)
                                message = xhr.responseJSON.message;

                            $("#notification").data("kendoNotification")
                                .show({ message: message }, "error");
                        }
                    });
                }
            });
        });

    </script>
}
