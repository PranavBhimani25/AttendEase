    color: var(--primary); margin-bottom: 12px;
}
.sec-label span { width: 20px; height: 2px; background: var(--primary); border-radius: 2px; display: inline-block; }
.sec-label.justify-center { justify-content: center; }
.sec-title {
    font-size: clamp(1.7rem, 3.5vw, 2.6rem);
