                "<div style='text-align: center; margin-bottom: 20px;'>" +
                "<div style='width: 80px; height: 80px; border-radius: 50%; background: linear-gradient(135deg, #0072c6, #0053a0); color: white; display: flex; align-items: center; justify-content: center; font-size: 36px; margin: 0 auto 10px;'>" + emp.name.charAt(0) + "</div>" +
                "<h3 style='margin: 0; color: #2c3e50;'>" + emp.name + "</h3>" +
                "<p style='color: #7f8c8d;'>" + emp.role + "</p>" +
                "</div>" +
                
                "<div style='display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 20px;'>" +
                "<div style='background: #f0f7ff; padding: 10px; border-radius: 5px; text-align: center;'>" +
                "<div style='font-size: 12px; color: #0072c6;'>Attendance Rate</div>" +
                "<div style='font-size: 24px; font-weight: bold; color: #2c3e50;'>95%</div>" +
                "</div>" +
                "<div style='background: #f0f7ff; padding: 10px; border-radius: 5px; text-align: center;'>" +
                "<div style='font-size: 12px; color: #0072c6;'>Avg Hours/Day</div>" +
                "<div style='font-size: 24px; font-weight: bold; color: #2c3e50;'>8.5</div>" +
                "</div>" +
                "</div>" +
                
                "<div id='quickAttendanceChart' style='height: 200px;'></div>" +
                "</div>";
            
            $("#detailsContent").html(content);
            window.center().open();
            
            // Initialize quick chart
            $("#quickAttendanceChart").kendoChart({
                legend: { visible: false },
                seriesDefaults: { type: "column" },
                series: [{
                    data: [8, 7, 9, 8, 7, 6, 8],
                    color: "#0072c6"
                }],
                categoryAxis: {
                    categories: ["Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun"],
                    labels: { rotation: 0 }
                },
                valueAxis: {
                    max: 10,
                    title: { text: "Hours" }
                }
            });
        });
    }

    function showDateRangePicker() {
        $("#dateRangeWindow").data("kendoWindow").center().open();
    }

    function loadCustomRangeData(startDate, endDate) {
        if (selectedEmployee) {
            $.getJSON("/Report/GetCustomRangeReport", {
                empid: selectedEmployee.empId,
                startDate: startDate.toISOString(),
                endDate: endDate.toISOString()
            }, function(data) {
                const grid = $("#reportGrid").data("kendoGrid");
                grid.dataSource.data(data);
                updateSummary(data);
            });
        }
    }

    function exportDashboard(format) {
        if (format === 'pdf') {
            kendo.drawing.drawDOM("#employeeGrid")
                .then(function(group) {
                    return kendo.drawing.exportPDF(group, {
                        paperSize: "auto",
                        margin: { left: "1cm", top: "1cm", right: "1cm", bottom: "1cm" }
                    });
                })
                .done(function(data) {
                    kendo.saveAs({
                        dataURI: data,
                        fileName: "dashboard_report.pdf"
                    });
                });
        }
    }

    function refreshAllData() {
        $("#employeeGrid").data("kendoGrid").dataSource.read();
        loadDashboardStats();
        kendo.ui.progress($("#employeeGrid"), false);
    }

