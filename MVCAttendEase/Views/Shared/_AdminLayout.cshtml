<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin</title>

    <!-- Bootstrap -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- Kendo UI -->
    <link rel="stylesheet" href="~/lib/kendo/kendo.common.min.css" />
    <link rel="stylesheet" href="~/lib/kendo/kendo.default-v2.min.css" />
    <link rel="stylesheet" href="~/lib/kendo/bootstrap-nordic.css" />

    <!-- Site CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body>

<div id="example">

    <!-- SIDEBAR -->
    <div id="sidebar">
        <div class="sidebar-header">
            <h4></h4>
        </div>

        <ul class="k-list-group">

            <li class="k-list-group-item">
                <span class="k-icon k-i-dashboard"></span>
                <a asp-controller="Admin" asp-action="Dashboard">Dashboard</a>
            </li>

            <li class="k-list-group-item">
                <span class="k-icon k-i-chart-bar"></span>
                <a asp-controller="Admin" asp-action="Report">Report</a>
            </li>

            <li class="k-list-group-item">
                <span class="k-icon k-i-user"></span>
                <a asp-controller="Auth" asp-action="Logout">Logout</a>
            </li>

        </ul>
    </div>


    <!-- MAIN CONTENT -->
    <div id="main">

        <!-- TOP BAR -->
        <div class="topbar">

            <button id="sidebar-toggle" class="k-button k-button-md k-rounded-md">
                <span class="k-icon k-i-menu"></span>
            </button>

            <h4 class="ms-3">@ViewData["Title"]</h4>

        </div>

        <div class="content-wrapper">

            @RenderBody()

        </div>

    </div>

</div>


<footer class="footer text-muted">
    <div class="container">
        &copy; 2026 - MVCAttendEase
    </div>
</footer>


<!-- Scripts -->
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/lib/kendo/kendo.all.min.js"></script>

<script>

$(document).ready(function () {

    $("#sidebar").kendoDrawer({
        mode: "push",
        mini: true,
        position: "left"
    });

    var drawer = $("#sidebar").data("kendoDrawer");

    $("#sidebar-toggle").click(function () {
        drawer.toggle();
    });

});

</script>

<style>

/* Layout */

#example{
    display:flex;
}

/* Sidebar */

#sidebar{
    width:250px;
    background:#2c3e50;
    color:white;
    min-height:100vh;
}

.sidebar-header{
    padding:20px;
    font-size:20px;
    font-weight:bold;
}

/* Sidebar items */

.k-list-group-item{
    padding:15px 20px;
    border:none;
    background:none;
}

.k-list-group-item a{
    color:white;
    text-decoration:none;
    margin-left:10px;
}

.k-list-group-item:hover{
    background:#34495e;
}

/* Top bar */

.topbar{
    display:flex;
    align-items:center;
    padding:15px;
    border-bottom:1px solid #ddd;
}

/* Content */

#main{
    flex:1;
}

.content-wrapper{
    padding:25px;
}

/* Footer */

.footer{
    text-align:center;
    padding:10px;
}

</style>

@await RenderSectionAsync("Scripts", required: false)

</body>
</html>