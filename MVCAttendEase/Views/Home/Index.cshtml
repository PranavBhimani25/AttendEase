}

.hero-ctas { display: flex; gap: 14px; flex-wrap: wrap; }

/* Hero stats — matches .stats-row from auth-left */
.hero-stats {
    display: flex; align-items: center; gap: 22px;
    margin-top: 36px; padding-top: 30px;
    border-top: 1px solid rgba(255,255,255,.15);
}
.hstat { display: flex; flex-direction: column; align-items: center; }
.hstat-num { color: #fff; font-size: 18px; font-weight: 700; line-height: 1; }
.hstat-label { color: rgba(255,255,255,.55); font-size: 11px; margin-top: 3px; }
.hstat-divider { width: 1px; height: 32px; background: rgba(255,255,255,.18); }

/* ── DASHBOARD MOCKUP (Hero Right) ── */
.hero-right { position: relative; }
.float-chip {
    position: absolute;
    background: #fff; border-radius: 14px;
    padding: 10px 14px; display: flex; align-items: center; gap: 10px;
    box-shadow: 0 8px 32px rgba(0,0,0,.18);
    z-index: 5; border: 1px solid var(--border);
}
.fc-top { top: -22px; left: -22px; animation: chipFloat 4s ease-in-out infinite; }
