@{
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
    ViewData["Title"] = "Login";
}

<div class="auth-wrapper">

    <!-- ════════════ LEFT PANEL ════════════ -->
    <div class="auth-left">
        <div class="left-content">
            <div class="brand-logo">
                <div class="logo-icon">
                    <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
