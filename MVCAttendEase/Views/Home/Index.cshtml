}
.bms-name { font-size: 13px; font-weight: 700; color: var(--text-dark); }
.bms-nav { display: flex; flex-direction: column; gap: 2px; }
.bms-item {
    display: flex; align-items: center; gap: 9px;
    padding: 8px 10px; border-radius: 9px;
    font-size: 12px; color: var(--text-soft); cursor: default;
    transition: .2s;
}
.bms-item:hover { background: rgba(99,102,241,.07); color: var(--text-dark); }
.bms-item.active { background: rgba(99,102,241,.1); color: var(--primary); font-weight: 600; }
.bms-item i { width: 14px; text-align: center; font-size: 12px; }

.bm-main { padding: 20px; display: flex; flex-direction: column; gap: 14px; }
.bm-kpi-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; }
.bm-kpi {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 12px; padding: 14px;
}
.bk-label { font-size: 11px; color: var(--text-soft); margin-bottom: 5px; }
.bk-val { font-size: 22px; font-weight: 800; color: var(--primary); font-family: 'Poppins'; }
.bk-change { font-size: 11px; margin-top: 3px; color: #10B981; display: flex; align-items: center; gap: 4px; }
.bk-change.dn { color: #EF4444; }

.bm-charts { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
.bm-chart-card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 12px; padding: 14px;
}
.bcc-title {
    font-size: 12.5px; font-weight: 600; color: var(--text-dark);
    margin-bottom: 12px; display: flex; justify-content: space-between; align-items: center;
}
.bcc-title span { font-size: 11px; color: var(--text-soft); font-weight: 400; }
.bar-chart { display: flex; gap: 5px; align-items: flex-end; height: 70px; margin-bottom: 6px; }
.bc-bar {
    flex: 1; border-radius: 4px 4px 0 0;
    background: linear-gradient(to top, var(--primary), var(--secondary));
    opacity: .7; transition: .2s;
}
.bc-bar.hi { opacity: 1; }
.bc-bar:hover { opacity: 1; transform: scaleY(1.03); }
.bc-labels { display: flex; gap: 5px; }
.bc-labels span { flex: 1; text-align: center; font-size: 9px; color: var(--text-soft); }

.donut-row { display: flex; align-items: center; gap: 18px; }
.donut-ring {
    width: 74px; height: 74px; border-radius: 50%; flex-shrink: 0;
    background: conic-gradient(#6366F1 0% 68%, #EC4899 68% 84%, #94A3B8 84%);
    position: relative;
}
.donut-ring::after {
    content: '68%'; position: absolute; inset: 14px;
    background: var(--surface); border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 11px; font-weight: 800; color: var(--primary);
}
.donut-legend { display: flex; flex-direction: column; gap: 8px; }
.dl-row { display: flex; align-items: center; gap: 8px; font-size: 12px; color: var(--text-mid); }
.dl-dot { width: 9px; height: 9px; border-radius: 3px; flex-shrink: 0; }

.bm-table-wrap {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 12px; overflow: hidden;
}
.bm-table { width: 100%; border-collapse: collapse; }
.bm-table th {
    font-size: 10.5px; color: var(--text-soft); font-weight: 600;
    text-transform: uppercase; letter-spacing: .5px;
    padding: 9px 14px; text-align: left; background: rgba(255,255,255,.5);
}
.bm-table td { font-size: 12.5px; color: var(--text-dark); padding: 9px 14px; border-top: 1px solid var(--border); }
.bm-table tr:hover td { background: rgba(99,102,241,.03); }
.t-emp { display: flex; align-items: center; gap: 8px; }
.t-av {
    width: 26px; height: 26px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 9px; font-weight: 700; color: #fff; flex-shrink: 0;
}
.t-badge { display: inline-block; padding: 2px 9px; border-radius: 6px; font-size: 11px; font-weight: 600; }
.t-badge.present { background: #ECFDF5; color: #065F46; }
.t-badge.late    { background: #FFFBEB; color: #92400E; }
.t-badge.absent  { background: #FEF2F2; color: #991B1B; }
.t-badge.office  { background: #EFF6FF; color: #1D4ED8; }
.t-badge.remote  { background: #F0FDF4; color: #166534; }
.t-badge.field   { background: #FFF7ED; color: #9A3412; }

/* ── TESTIMONIALS ── */
.testi-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 18px; }
.testi-card {
    background: #fff; border: 1px solid var(--border);
    border-radius: 20px; padding: 26px;
    box-shadow: 0 2px 12px rgba(0,0,0,.04);
    transition: .3s; position: relative; overflow: hidden;
}
.testi-card::before {
    content: '"'; font-size: 80px; font-weight: 800;
    position: absolute; top: -10px; right: 18px;
    color: var(--primary); opacity: .06; line-height: 1;
}
.testi-card:hover { transform: translateY(-4px); box-shadow: 0 14px 40px rgba(99,102,241,.1); border-color: rgba(99,102,241,.2); }
.testi-stars { display: flex; gap: 3px; margin-bottom: 12px; color: #F59E0B; font-size: 13px; }
.testi-text { color: var(--text-mid); font-size: 13.5px; line-height: 1.7; font-style: italic; margin-bottom: 18px; }
.testi-author { display: flex; align-items: center; gap: 12px; }
.testi-av {
    width: 40px; height: 40px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-weight: 700; font-size: 13px; color: #fff; flex-shrink: 0;
}
.testi-name { font-size: 13.5px; font-weight: 700; color: var(--text-dark); }
.testi-role { font-size: 12px; color: var(--text-soft); margin-top: 1px; }

/* ── CTA ── */
.lp-cta { padding: 80px 0; }
.cta-card {
    background: linear-gradient(135deg, #312E81 0%, #4F46E5 40%, #7C3AED 75%, #BE185D 100%);
    border-radius: 28px; padding: 70px 60px;
    text-align: center; position: relative; overflow: hidden;
}
.cta-blob {
    position: absolute; border-radius: 50%;
    filter: blur(60px); opacity: .25; pointer-events: none;
}
.cta-blob.c1 { width: 350px; height: 350px; background: #A78BFA; top: -100px; right: -80px; }
.cta-blob.c2 { width: 280px; height: 280px; background: #F472B6; bottom: -80px; left: -60px; }
.cta-title {
    font-size: clamp(1.7rem,3.5vw,2.5rem); font-weight: 800;
    color: #fff; letter-spacing: -1.5px; margin-bottom: 14px;
    position: relative; z-index: 1;
}
.cta-sub { color: rgba(255,255,255,.7); font-size: 15px; margin-bottom: 32px; position: relative; z-index: 1; }
.cta-btns { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; margin-bottom: 24px; position: relative; z-index: 1; }
.cta-pills { display: flex; gap: 10px; justify-content: center; flex-wrap: wrap; position: relative; z-index: 1; }

/* ── FOOTER ── */
.lp-footer { background: var(--surface); border-top: 1px solid var(--border); padding: 60px 0 28px; }
.footer-top { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 40px; margin-bottom: 44px; }
.footer-brand-col .lp-logo-text { color: var(--text-dark); }
.footer-desc { color: var(--text-soft); font-size: 13px; line-height: 1.7; max-width: 260px; margin: 4px 0 20px; }
.footer-socials { display: flex; gap: 9px; }
.soc-btn {
    width: 36px; height: 36px; border-radius: 9px;
    background: #fff; border: 1px solid var(--border);
    display: flex; align-items: center; justify-content: center;
    color: var(--text-soft); font-size: 13px; text-decoration: none;
    transition: .25s;
}
.soc-btn:hover { background: var(--primary); color: #fff; border-color: var(--primary); transform: translateY(-2px); }
.footer-col-title { font-size: 13px; font-weight: 700; color: var(--text-dark); margin-bottom: 16px; }
.footer-links { list-style: none; display: flex; flex-direction: column; gap: 10px; }
.footer-links a { text-decoration: none; color: var(--text-soft); font-size: 13px; transition: .2s; }
.footer-links a:hover { color: var(--primary); }
.footer-bottom {
    border-top: 1px solid var(--border); padding-top: 22px;
    display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 12px;
}
.footer-copy { font-size: 12.5px; color: var(--text-soft); }
.footer-bottom-links { display: flex; gap: 18px; }
.footer-bottom-links a { font-size: 12.5px; color: var(--text-soft); text-decoration: none; transition: .2s; }
.footer-bottom-links a:hover { color: var(--primary); }

/* ── SCROLL ANIMATIONS ── */
.fade-up {
    opacity: 0; transform: translateY(30px);
    transition: opacity .65s ease, transform .65s ease;
}
.fade-up.visible { opacity: 1; transform: translateY(0); }

/* ── RESPONSIVE ── */
@@media (max-width: 1024px) {
    .hero-inner { grid-template-columns: 1fr; }
    .hero-right { display: none; }
    .features-grid { grid-template-columns: repeat(2, 1fr); }
    .footer-top { grid-template-columns: 1fr 1fr; }
    .bm-sidebar { display: none; }
    .bm-body { grid-template-columns: 1fr; }
}
@@media (max-width: 768px) {
    .lp-nav-links { display: none; }
    .lp-hamburger { display: flex; }
    .steps-row { grid-template-columns: 1fr; }
    .testi-grid { grid-template-columns: 1fr; }
    .bm-kpi-row { grid-template-columns: repeat(2, 1fr); }
    .bm-charts { grid-template-columns: 1fr; }
    .cta-card { padding: 48px 24px; }
    .footer-top { grid-template-columns: 1fr; }
    .footer-bottom { flex-direction: column; text-align: center; }
}
@@media (max-width: 480px) {
    .features-grid { grid-template-columns: 1fr; }
    .hero-stats { gap: 14px; }
    .trust-strip .lp-container { flex-direction: column; align-items: flex-start; }
    .bm-kpi-row { grid-template-columns: 1fr 1fr; }
}
</style>

<script>
$(function () {
    // ── Navbar scroll ──
    $(window).on('scroll', function () {
        $('#lpNav').toggleClass('scrolled', $(this).scrollTop() > 50);
    });

    // ── Mobile nav ──
    $('#hamburgerBtn').on('click', function () {
        $('#mobileOverlay').addClass('open');
    });
    $('#mobileClose').on('click', function () {
        $('#mobileOverlay').removeClass('open');
    });
    $('#mobileOverlay .mob-link, #mobileOverlay .mob-btn').on('click', function () {
        $('#mobileOverlay').removeClass('open');
    });

    // ── Smooth scroll ──
    $('a[href^="#"]').on('click', function (e) {
        var target = $(this.getAttribute('href'));
        if (target.length) {
            e.preventDefault();
            $('html, body').animate({ scrollTop: target.offset().top - 72 }, 600, 'swing');
        }
    });

    // ── Scroll reveal ──
    var observer = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
            if (entry.isIntersecting) {
                entry.target.classList.add('visible');
            }
        });
    }, { threshold: 0.12, rootMargin: '0px 0px -36px 0px' });

    document.querySelectorAll('.fade-up').forEach(function (el) {
        observer.observe(el);
    });

    // ── Kendo Notification ──
    var $notif = $('<div id="lpNotif"></div>').appendTo('body');
    var kNotif = $notif.kendoNotification({
        position: { pinned: true, top: 80, right: 20 },
        autoHideAfter: 3500,
        stacking: 'down',
        templates: [{
            type: 'info',
            template: '<div style="padding:4px 8px"><i class="fa fa-info-circle"></i> #= message #</div>'
        }]
    }).data('kendoNotification');

    // ── Kendo Tooltip on CTA buttons ──
    $('[href="/Auth/Register"]').first().kendoTooltip({
        content: 'Create your free account in 60 seconds',
        position: 'bottom',
        showAfter: 400
    });

    // Welcome toast
    setTimeout(function () {
        kNotif.show({ message: 'Welcome to AttendEase — explore the features below!' }, 'info');
    }, 1800);
});
</script>
}
