<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/kendo/kendo.default-v2.min.css" />
    <link rel="stylesheet" href="~/lib/kendo/bootstrap-nordic.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body>

<div id="example">

    <!-- SIDEBAR -->
    <div id="sidebar">
        <div class="sidebar-header">
            <h4>Admin</h4>
        </div>

        <ul class="k-list-group">
            <li class="k-list-group-item">
                <span class="k-icon k-i-home"></span>
                <a asp-controller="Admin" asp-action="Dashboard">Dashboard</a>
            </li>
            <li class="k-list-group-item">
                <span class="k-icon k-i-chart-line"></span>
                <a asp-controller="Admin" asp-action="Report">Report</a>
            </li>
            <li class="k-list-group-item">
                <span class="k-icon k-i-user"></span>
                <a asp-controller="Auth" asp-action="Logout">Logout</a>
            </li>
        </ul>
    </div>

    <!-- MAIN CONTENT -->
    <div id="main">

        <!-- TOP BAR -->
        <div class="topbar">
            <div class="topbar-left">
                <button id="sidebar-toggle" class="k-button k-button-md k-rounded-md">
                    <span class="k-icon k-i-menu"></span>
                </button>
                <h4 class="ms-3">@ViewData["Title"]</h4>
            </div>
            <div class="topbar-actions">
                <div class="notification-wrapper">

                    <!-- ── BELL BUTTON (redesigned) ── -->
                    <button id="admin-notification-btn" type="button" class="notif-bell-btn" aria-haspopup="true" aria-expanded="false">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"
                             stroke-linecap="round" stroke-linejoin="round" width="18" height="18">
                            <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
                            <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
                        </svg>
                        <span class="notif-badge" id="notification-count" aria-live="polite"></span>
                    </button>

                    <!-- ── DROPDOWN (redesigned) ── -->
                    <div class="notification-dropdown" id="notification-dropdown" role="region" aria-label="Recent notifications">
                        <div class="notification-header">
                            <div class="d-flex justify-content-between align-items-center gap-4">
                                <strong>Notifications</strong>
                                <button id="mark-all-read" class="btn btn-sm btn-outline-secondary">Mark All Read</button>
                                <button id="see-all-notifications" class="btn btn-sm btn-outline-primary ms-1" title="See all notifications">See ALL</button>
                            </div>
                        </div>
                        <div class="notification-body">
                            <ul class="notification-items" id="notification-items"></ul>
                            <div class="notification-empty" id="notification-empty">You're all caught up.</div>
                        </div>
                    </div>

                </div>
            </div>
        </div>

        <div class="content-wrapper">
            @RenderBody()
        </div>

    </div>

</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/lib/kendo/kendo.all.min.js"></script>

<script>
$(document).ready(function () {
    $("#sidebar-toggle").click(function () {
        $("#sidebar").toggleClass("collapsed");
    });

    initAdminNotifications();
});

function initAdminNotifications() {
    var bellBtn = document.getElementById("admin-notification-btn");
    var dropdown = document.getElementById("notification-dropdown");
    var notificationItems = document.getElementById("notification-items");
    var emptyState = document.getElementById("notification-empty");
    var badge = document.getElementById("notification-count");

    if (!bellBtn || !dropdown || !notificationItems || !badge) {
        return;
    }

     var notifications = [];
    var unreadCount = 0;
    var MAX_ITEMS = 6;

    // Load persistent unread count and history from server
    Promise.all([
        fetchUnreadCount().then(count => {
            unreadCount = count;
            updateBadge();
        }),
        fetchHistory()
    ]).catch(e => console.warn('Load notifications failed', e));

   

    var eventSource;
    if (window.EventSource) {
        eventSource = new EventSource("/Notifications/Stream");
        eventSource.onmessage = function (event) {
            try {
                var payload = JSON.parse(event.data);
                addNotification(payload);
            } catch (err) {
                console.error("Failed to parse notification payload", err);
            }
        };

        eventSource.onerror = function () {
            if (eventSource.readyState === EventSource.CLOSED) {
                closeStream();
            }
        };
    }

    async function fetchHistory(max = MAX_ITEMS) {
        try {
            const res = await fetch(`/Notifications/history?count=${max}`);
            if (res.ok) {
                const history = await res.json();
                notifications = history;
                renderNotifications();
            }
        } catch (e) {
            console.warn('Failed to fetch notification history:', e);
        }
    }

    function closeStream() {
        if (eventSource) {
            eventSource.close();
            eventSource = null;
        }
    }

    window.addEventListener("beforeunload", closeStream);

    function addNotification(payload) {
        notifications.unshift(payload);
        if (notifications.length > MAX_ITEMS) {
            notifications.length = MAX_ITEMS;
        }
        unreadCount++;
        updateBadge();
        renderNotifications();
    }

    // ── CHANGED: renderNotifications — avatar initials + unread dot ──
    function renderNotifications() {
        notificationItems.innerHTML = "";
        if (notifications.length === 0) {
            emptyState.style.display = "block";
            return;
        }

        emptyState.style.display = "none";

        var avatarColors = [
            { bg: "#e6f1fb", color: "#185FA5" },
            { bg: "#EEEDFE", color: "#534AB7" },
            { bg: "#E1F5EE", color: "#0F6E56" },
            { bg: "#FAECE7", color: "#993C1D" }
        ];

        notifications.forEach(function (item, index) {
            var listItem = document.createElement("li");
            listItem.className = "notification-item";
            listItem.dataset.index = index;

            listItem.addEventListener("click", function() {
                markItemRead(index);
            });

            // Unread dot
            var dot = document.createElement("div");
            dot.className = index < unreadCount ? "notif-unread-dot" : "notif-read-spacer";

           // Avatar with initials + type icon overlay
            var avatar = document.createElement("div");
            avatar.className = "notif-avatar";
            var type = item?.notificationType || "Registration";

            // Color scheme per type
            if (type === "CheckIn") {
                avatar.style.background = "#E1F5EE";
                avatar.style.color = "#0F6E56";
            } else if (type === "CheckOut") {
                avatar.style.background = "#FAECE7";
                avatar.style.color = "#993C1D";
            } else {
                var scheme = avatarColors[index % avatarColors.length];
                avatar.style.background = scheme.bg;
                avatar.style.color = scheme.color;
            }

            var name = item?.fullName || "NU";
            var parts = name.trim().split(" ");
            avatar.textContent = parts.length >= 2
                ? (parts[0][0] + parts[parts.length - 1][0]).toUpperCase()
                : name.substring(0, 2).toUpperCase();

            // Content wrapper
            var content = document.createElement("div");
            content.style.flex = "1";
            content.style.minWidth = "0";

            var header = document.createElement("div");
            header.className = "notification-header-item";
            header.textContent = item?.fullName || "New user";

            var body = document.createElement("div");
            body.className = "notification-body-item";
            body.textContent = item?.message || "A new user has registered.";
            
            // Add a small type pill
            var typePill = document.createElement("span");
            typePill.className = "notif-type-pill notif-type-" + (item?.notificationType || "Registration").toLowerCase();
            typePill.textContent = item?.notificationType || "Registration";
            body.appendChild(typePill);

            var footer = document.createElement("div");
            footer.className = "notification-footer-item";
            var time = document.createElement("small");
            if (item?.registeredAt) {
                var date = new Date(item.registeredAt);
                if (!Number.isNaN(date.getTime())) {
                    time.textContent = date.toLocaleString(undefined, { hour12: true });
                }
            }
            footer.appendChild(time);

            content.appendChild(header);
            content.appendChild(body);
            content.appendChild(footer);

            listItem.appendChild(dot);
            listItem.appendChild(avatar);
            listItem.appendChild(content);

            notificationItems.appendChild(listItem);
        });
    }

    // ── CHANGED: updateBadge — empty string instead of "0" when hidden ──
    function updateBadge() {
        if (unreadCount <= 0) {
            badge.classList.remove("visible");
            badge.textContent = "";
            return;
        }
        badge.classList.add("visible");
        badge.textContent = unreadCount > 99 ? "99+" : unreadCount;
    }

    bellBtn.addEventListener("click", function (event) {
        event.stopPropagation();
        var isOpen = dropdown.classList.toggle("open");
        bellBtn.setAttribute("aria-expanded", isOpen.toString());
        if (isOpen) {
            fetchHistory(); // Refresh list
        }
    });

    document.getElementById("mark-all-read").addEventListener("click", function(e) {
        e.stopPropagation();
        markAllRead();
    });

    // See ALL full modal
    document.getElementById("see-all-notifications").addEventListener("click", function(e) {
        e.stopPropagation();
        showAllNotificationsModal();
    });

    function showAllNotificationsModal() {
            // Remove old modal completely so spinner always resets fresh
            const old = document.getElementById("notification-modal-backdrop");
            if (old) old.remove();

            const backdrop = document.createElement("div");
            backdrop.id        = "notification-modal-backdrop";
            backdrop.className = "notification-modal-backdrop";
            backdrop.innerHTML = `
                <div class="notification-modal">
                    <div class="notification-modal-header">
                        <h5>All Notifications</h5>
                        <button class="close-modal-btn" onclick="closeAllNotificationsModal()">
                            <span class="k-icon k-i-close"></span>
                        </button>
                    </div>
                    <div class="notification-modal-body" id="all-notifications-list">
                        <div class="text-center p-4">
                            <div class="spinner-border" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                        </div>
                    </div>
                </div>
            `;
            document.body.appendChild(backdrop);

            // Small delay taaki DOM append ho jaye pehle
            requestAnimationFrame(() => {
                backdrop.classList.add("show");
                loadAllNotifications();
            });
    }

    function closeAllNotificationsModal() {
    const backdrop = document.getElementById("notification-modal-backdrop");
    if (backdrop) {
        backdrop.classList.remove("show");
    }
}
window.closeAllNotificationsModal = closeAllNotificationsModal; // expose to global scope

    // ── CHANGED: loadAllNotifications — avatar initials added to modal cards ──
    async function loadAllNotifications() {
        try {
            const res = await fetch('/Notifications/history?count=100');
            if (res.ok) {
                const allNotifications = await res.json();
                const list = document.getElementById("all-notifications-list");
                list.innerHTML = "";
                if (allNotifications.length === 0) {
                    list.innerHTML = '<div class="text-center p-4 text-muted">No notifications</div>';
                    return;
                }

                const avatarColors = [
                    { bg: "#e6f1fb", color: "#185FA5" },
                    { bg: "#EEEDFE", color: "#534AB7" },
                    { bg: "#E1F5EE", color: "#0F6E56" },
                    { bg: "#FAECE7", color: "#993C1D" }
                ];

                allNotifications.forEach((item, index) => {
                    const scheme = avatarColors[index % avatarColors.length];
                    const name = item.fullName || "NU";
                    const parts = name.trim().split(" ");
                    const initials = parts.length >= 2
                        ? (parts[0][0] + parts[parts.length - 1][0]).toUpperCase()
                        : name.substring(0, 2).toUpperCase();

                    const card = document.createElement("div");
                    card.className = "notification-card";
                    card.innerHTML = `
                        <div class="notif-avatar" style="background:${scheme.bg};color:${scheme.color};width:38px;height:38px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:600;flex-shrink:0;">${initials}</div>
                        <div style="flex:1;min-width:0;">
                            <div class="card-header"><strong>${item.fullName || 'New User'}</strong></div>
                            <div class="card-body">
                                <p>${item.message}</p>
                                <small class="text-muted">${new Date(item.registeredAt).toLocaleString()}</small>
                            </div>
                        </div>
                    `;
                    list.appendChild(card);
                });
            }
       } catch (e) {
            console.error('Failed to load all notifications:', e);
            const list = document.getElementById("all-notifications-list");
            if (list) {
                list.innerHTML = '<div class="text-center p-4 text-danger">Failed to load notifications. Please try again.</div>';
            }
        }
    }

    document.addEventListener("click", function (event) {
        if (!dropdown.contains(event.target) && event.target !== bellBtn) {
            dropdown.classList.remove("open");
            bellBtn.setAttribute("aria-expanded", "false");
        }
    });

    document.addEventListener("keydown", function (event) {
        if (event.key === "Escape") {
            dropdown.classList.remove("open");
            bellBtn.setAttribute("aria-expanded", "false");
        }
    });

    async function markAllRead() {
        try {
            const res = await fetch('/Notifications/markallread', { 
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
            });
            if (res.ok) {
                unreadCount = 0;
                updateBadge();
                notifications = [];
                renderNotifications();
                emptyState.style.display = "block";
            }
        } catch (e) {
            console.warn('Failed to mark all read:', e);
        }
    }

    async function markItemRead(index) {
        try {
            const res = await fetch(`/Notifications/markread/${index}`, { 
                method: 'POST'
            });
            if (res.ok) {
                notifications.splice(index, 1);
            renderNotifications();
                // Server se fresh count lo — local decrement reliable nahi hai
                const freshCount = await fetchUnreadCount();
                unreadCount = Math.max(0, freshCount);
                updateBadge();
                await fetchHistory();
            }
        } catch (e) {
            console.warn('Failed to mark item read:', e);
        }
    }

    async function fetchUnreadCount() {
        try {
            const res = await fetch('/Notifications/unreadcount');
            if (res.ok) {
                return await res.json();
            }
        } catch (e) {
            console.warn('Failed to fetch unread count:', e);
        }
        return 0;
    }

    function resetUnreadCount() {
        // Deprecated - use markAllRead
    }
}
</script>

<style>
/* ── UNCHANGED: Layout ── */

html, body {
    height: 100%;
    margin: 0;
}

#example {
    display: flex;
    min-height: 100vh;
}

.content-wrapper {
    padding: 20px 20px 0 20px;
    flex: 1;
}

.k-grid {
    margin-bottom: 0 !important;
}

#example {
    display: flex;
    min-height: 100vh;
}


/* ── UNCHANGED: Sidebar ── */
#sidebar {
    width: 250px;
    background: #2c3e50;
    color: white;
    min-height: 100vh;
    transition: width 0.3s ease;
    overflow: hidden;
    flex-shrink: 0;
}

#sidebar.collapsed {
    width: 60px;
}

.sidebar-header {
    padding: 20px;
    font-size: 20px;
    font-weight: bold;
    white-space: nowrap;
}

#sidebar.collapsed .sidebar-header h4 {
    display: none;
}

.k-list-group-item {
    padding: 15px 20px;
    border: none !important;
    background: none !important;
    white-space: nowrap;
    display: flex;
    align-items: center;
}

.k-list-group-item a {
    color: white;
    text-decoration: none;
    margin-left: 10px;
    transition: opacity 0.2s;
}

#sidebar.collapsed .k-list-group-item a {
    display: none;
}
#sidebar.collapsed {
    width: 0;
    padding: 0;
}

.k-list-group-item:hover {
    background: #34495e !important;
}

.k-list-group-item .k-icon {
    color: white;
    flex-shrink: 0;
}

/* ── UNCHANGED: Top bar ── */
.topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 15px;
    border-bottom: 1px solid #ddd;
    gap: 1rem;
}

.topbar-left {
    display: flex;
    align-items: center;
    gap: 0.75rem;
}

.topbar-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

/* ════════════════════════════════════════════
   NOTIFICATION UI — REDESIGNED
   ════════════════════════════════════════════ */

.notification-wrapper {
    position: relative;
}

/* Bell button */
.notif-bell-btn {
    position: relative;
    width: 42px;
    height: 42px;
    border-radius: 12px;
    background: #f4f5f7;
    border: 1px solid #e2e5ea;
    color: #374151;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background .15s, border-color .15s;
}
.notif-bell-btn:hover {
    background: #e9ebee;
}
.notif-bell-btn[aria-expanded="true"] {
    background: #e6f1fb;
    border-color: #b5d4f4;
    color: #185FA5;
}

/* Badge */
.notif-badge {
    position: absolute;
    top: -5px;
    right: -5px;
    min-width: 18px;
    height: 18px;
    border-radius: 20px;
    background: #E24B4A;
    color: #fff;
    font-size: 10px;
    font-weight: 600;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 0 4px;
    border: 2px solid #fff;
    animation: badgePop .3s cubic-bezier(.34,1.56,.64,1);
}
.notif-badge.visible {
    display: flex;
}
@@keyframes badgePop {
    from { transform: scale(0); }
    to   { transform: scale(1); }
}

/* Dropdown panel */
.notification-dropdown {
    display: none;
    position: absolute;
    right: 0;
    top: calc(100% + 10px);
    width: 340px;
    background: #fff;
    border-radius: 16px;
    border: 0.5px solid #dde1e7;
    box-shadow: 0 8px 32px rgba(0,0,0,.10);
    overflow: hidden;
    z-index: 40;
}
.notification-dropdown.open {
    display: block;
}

.notification-header {
    padding: 13px 16px;
    border-bottom: 0.5px solid #f1f3f5;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
}
.notification-header strong {
    font-size: 13px;
    font-weight: 500;
}

.notification-body {
    max-height: 300px;
    overflow: hidden;
}

/* Notification list */
.notification-items {
    list-style: none;
    margin: 0;
    padding: 0;
    max-height: 260px;
    overflow-y: auto;
}

.notification-item {
    padding: 11px 15px;
    border-bottom: 0.5px solid #f1f3f5;
    display: flex;
    gap: 10px;
    align-items: flex-start;
    cursor: pointer;
    transition: background .12s;
}
.notification-item:hover {
    background: #f8f9ff;
}
.notification-item:last-child {
    border-bottom: none;
}

/* Unread dot / read spacer */
.notif-unread-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #378ADD;
    flex-shrink: 0;
    margin-top: 6px;
}
.notif-read-spacer {
    width: 7px;
    flex-shrink: 0;
}

/* Avatar circle */
.notif-avatar {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    font-weight: 600;
    flex-shrink: 0;
    background: #e6f1fb;
    color: #185FA5;
}

/* Item text */
.notification-header-item {
    font-size: 12px;
    font-weight: 500;
    color: #111;
    margin-bottom: 2px;
}
.notification-body-item {
    font-size: 11.5px;
    color: #5a6472;
    line-height: 1.45;
}
.notification-footer-item small {
    font-size: 10.5px;
    color: #9ba3ad;
}

/* Empty state */
.notification-empty {
    padding: 16px;
    text-align: center;
    font-size: 0.85rem;
    color: #868686;
}

/* Full modal backdrop */
.notification-modal-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(10,10,20,.45);
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    transition: opacity .25s ease, visibility .25s ease;
}
.notification-modal-backdrop.show {
    opacity: 1;
    visibility: visible;
}

/* Modal box */
.notification-modal {
    background: #fff;
    border-radius: 20px;
    width: 90vw;
    max-width: 560px;
    max-height: 82vh;
    overflow: hidden;
    border: 0.5px solid #dde1e7;
    box-shadow: 0 24px 60px rgba(0,0,0,.18);
    animation: modalSlideIn .25s cubic-bezier(.34,1.26,.64,1);
}
@@keyframes modalSlideIn {
    from { transform: scale(.92) translateY(16px); opacity: 0; }
    to   { transform: scale(1)   translateY(0);    opacity: 1; }
}

.notification-modal-header {
    padding: 18px 22px;
    border-bottom: 0.5px solid #f1f3f5;
    display: flex;
    justify-content: space-between;
    align-items: center;
}
.notification-modal-header h5 {
    font-size: 14px;
    font-weight: 500;
    margin: 0;
}

.notif-count-badge {
    font-size: 10px;
    padding: 2px 8px;
    background: #e6f1fb;
    color: #185FA5;
    border-radius: 20px;
    font-weight: 600;
    margin-left: 8px;
}

/* Close button */
.close-modal-btn {
    width: 30px;
    height: 30px;
    border-radius: 8px;
    background: #f4f5f7;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    color: #6b7280;
    transition: background .12s;
}
.close-modal-btn:hover {
    background: #e9ebee;
}

/* Modal scrollable body */
.notification-modal-body {
    max-height: calc(82vh - 130px);
    overflow-y: auto;
}

/* Modal notification cards */
.notification-card {
    padding: 14px 22px;
    display: flex;
    gap: 12px;
    border-bottom: 0.5px solid #f1f3f5;
    cursor: pointer;
    transition: background .12s;
    align-items: flex-start;
}
.notification-card:hover {
    background: #f8f9ff;
}
.notification-card:last-child {
    border-bottom: none;
}

.card-header {
    font-size: 13px;
    font-weight: 500;
    color: #111;
    margin-bottom: 3px;
    padding: 0;
    background: none;
    border: none;
}
.card-body {
    padding: 0;
}
.card-body p {
    font-size: 12px;
    color: #5a6472;
    margin: 0 0 5px;
    line-height: 1.5;
}
.card-body small {
    font-size: 11px;
    color: #9ba3ad;
}

.notif-type-pill {
    display: inline-block;
    font-size: 9.5px;
