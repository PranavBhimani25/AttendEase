@{
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
    ViewData["Title"] = "Login";
}

<div class="login-wrapper">

    <!-- LEFT -->
    <div class="login-left">
    </div>

    <!-- RIGHT -->
    <div class="login-right">

        <div class="login-card">

            <div class="user-icon">
                <i class="fa fa-user"></i>
            </div>

            <h2 class="welcome-text">WELCOME</h2>

            <form id="loginForm"></form>

            <div class="forgot-text">
                <a href="/Auth/ForgetPassword">Forgot Password?</a>
            </div>

            <div id="notification"></div>

            <div class="register-text">
                Don’t have an account?
                <a href="/Auth/Register">Register</a>
            </div>

        </div>

    </div>

</div>


@section Scripts{
    <style>
        .login-left {
            flex: 1;

            background: url('https://res.cloudinary.com/dvs3znyc7/image/upload/v1773998933/WhatsApp_Image_2026-03-20_at_2.57.47_PM_yenyfh.jpg');

            background-size: cover;       /* 🔥 fill entire area */
            background-position: center;  /* center image */
            background-repeat: no-repeat;

            display: flex;
            align-items: center;
            justify-content: center;
        }
    </style>

<script>
    $(document).ready(function () {

        $("#notification").kendoNotification({
            position: {
                pinned: true,
                top: 30,
                right: 30
            },
            autoHideAfter: 1500
        });

        $("#loginForm").kendoForm({

            formData: {
                c_email: "",
                c_password: ""
            },

            items: [
                {
                    field: "email",
                    label: "Email",
                    validation: {
                        required: { message: "Email is required" },
                        email: { message: "Invalid email format" }
                    },
                    editor: function (container, options) {
                        $('<input name="' + options.field + '" type="email"/>')
                            .appendTo(container)
                            .kendoTextBox({
                                placeholder: "Enter your email"
                            });
                    }
                },
                {
                    field: "password",
                    label: "Password",
                    validation: {
                        required: { message: "Password is required" }
                    },
                    editor: function (container, options) {
                        $('<input name="' + options.field + '" type="password"/>')
                            .appendTo(container)
                            .kendoTextBox({
                                placeholder: "Enter password"
                            });
                    }
                }
            ],

            buttonsTemplate: `
                <button type="submit" class="k-button k-primary w-100">
                    LOGIN
                </button>
            `,

            submit: function (e) {
                e.preventDefault();

                var formdata = {
                    c_email: e.model.email,
                    c_password: e.model.password
                };

                $.ajax({
                    url: "/Auth/Login",
                    method: "POST",
                    data: JSON.stringify(formdata),
                    contentType: "application/json",

                    success: function (response) {

                        if (response.success) {
                            $("#notification").data("kendoNotification")
                                .show("Login successful!", "success");

                            sessionStorage.setItem("userRole", response.role);
                            sessionStorage.setItem("userId", response.id);

                            if (response.role === "Admin") {
                                setTimeout(() => window.location.href = "/Admin/Dashboard", 1500);
                            } else {
                                setTimeout(() => window.location.href = "/Employee/Dashboard", 1500);
                            }

                        } else {
                            $("#notification")
                                .data("kendoNotification")
                                .show("Invalid credentials", "error");
                        }
                    },

                    error: function () {
                        $("#notification")
                            .data("kendoNotification")
                            .show("Login failed", "error");
                    }
                });
            }
        });

    });
</script>
}