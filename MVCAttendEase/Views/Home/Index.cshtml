.mb-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 14px; }
.mb-title { font-size: 13px; font-weight: 700; color: var(--text-dark); }
.mb-month { font-size: 11px; color: var(--text-soft); background: var(--surface); padding: 3px 10px; border-radius: 6px; border: 1px solid var(--border); }
.mb-kpis { display: grid; grid-template-columns: repeat(3,1fr); gap: 8px; margin-bottom: 12px; }
.mb-kpi { background: var(--surface); border: 1px solid var(--border); border-radius: 10px; padding: 10px; }
.kpi-val { font-size: 20px; font-weight: 800; color: var(--primary); font-family: 'Poppins', sans-serif; }
.kpi-lbl { font-size: 10px; color: var(--text-soft); margin-top: 1px; }
.mb-chart { background: var(--surface); border-radius: 10px; border: 1px solid var(--border); padding: 10px; margin-bottom: 12px; }
.mb-chart-label { font-size: 10px; color: var(--text-soft); margin-bottom: 8px; }
.mini-bars { display: flex; gap: 5px; align-items: flex-end; height: 50px; }
.mini-bar {
    flex: 1; border-radius: 4px 4px 0 0;
    background: linear-gradient(to top, var(--primary), var(--secondary));
    opacity: .45; transition: opacity .2s;
}
.mini-bar.hi { opacity: .85; }
.mini-bar:hover { opacity: 1; }
.mb-list { display: flex; flex-direction: column; gap: 6px; }
.mb-row {
    display: flex; align-items: center; gap: 9px;
