<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - AttendEase</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MVCAttendEase.styles.css" asp-append-version="true" />
    @* <link rel="stylesheet" href="~/lib/kendo/kendo.default-v2.min.css" /> *@
    <link rel="stylesheet" href="~/lib/kendo/bootstrap-nordic.css" />



    <style>

        body{
            font-family: 'Poppins', sans-serif;
            background: linear-gradient(135deg,#1E3A8A,#3B82F6);
            min-height:100vh;
            display:flex;
            justify-content:center;
            align-items:flex-start;   /* changed */
            padding-top:60px;         /* space from top */
            padding-bottom:60px;
        }

        .auth-container{
            width:100%;
            max-width:520px;
        }

        .auth-card{
            background:white;
            padding:35px;
            border-radius:12px;
            box-shadow:0 12px 30px rgba(0,0,0,0.2);
        }

        .auth-title{
            text-align:center;
            font-size:28px;
            font-weight:600;
            margin-bottom:10px;
            color:#1E3A8A;
        }

        .auth-subtitle{
            text-align:center;
            color:#777;
            margin-bottom:30px;
        }

        .auth-footer{
            text-align:center;
            margin-top:20px;
        }

        .auth-footer a{
            color:#3B82F6;
            text-decoration:none;
            font-weight:500;
        }

        .k-button{
            background:#3B82F6;
            border:none;
        }

        .k-button:hover{
            background:#1E40AF;
        }
                /* ===================== PRELOADER STYLES ===================== */
        #preloader {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.72);
            z-index: 9999;
            justify-content: center;
            align-items: center;
        }

        #preloader.show {
            display: flex;
        }

        .preloader-box {
            background: #0F1117;
            padding: 36px 48px;
            border-radius: 16px;
            text-align: center;
            border: 0.5px solid rgba(255, 255, 255, 0.08);
            min-width: 230px;
        }

        .spinner {
            position: relative;
            width: 52px;
            height: 52px;
            margin: 0 auto 20px auto;
        }

        .spinner-ring-outer,
        .spinner-ring-inner {
            position: absolute;
            top: 0;
            left: 0;
        }

        .spinner-ring-outer {
            animation: spin 1.4s linear infinite;
        }

        .spinner-ring-inner {
            animation: spin-reverse 2s linear infinite;
        }

        .spinner-dot {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: #C4B5FD;
            animation: pulse 1.4s ease-in-out infinite;
        }

        @@keyframes spin {
            to { transform: rotate(360deg); }
        }

        @@keyframes spin-reverse {
            to { transform: rotate(-360deg); }
        }

        @@keyframes pulse {
            0%, 100% { opacity: 1; transform: translate(-50%, -50%) scale(1); }
            50%       { opacity: 0.4; transform: translate(-50%, -50%) scale(0.6); }
        }

        .preloader-box p {
            margin: 0;
            font-size: 15px;
            font-weight: 500;
            color: #E2E8F0;
            letter-spacing: 0.01em;
        }

        .preloader-box small {
            display: block;
            margin-top: 8px;
            font-size: 12px;
            color: #4B5563;
        }
        /* ============================================================ */

    </style>

</head>

<body>
    <!-- ===================== PRELOADER HTML ===================== -->
<div id="preloader">
    <div class="preloader-box">
        <div class="spinner">
            <svg class="spinner-ring-outer" width="52" height="52" viewBox="0 0 52 52">
                <circle cx="26" cy="26" r="22" fill="none" stroke="rgba(139,92,246,0.15)" stroke-width="3.5"/>
                <circle cx="26" cy="26" r="22" fill="none" stroke="#8B5CF6" stroke-width="3.5"
                    stroke-dasharray="138" stroke-dashoffset="100" stroke-linecap="round"/>
            </svg>
            <svg class="spinner-ring-inner" width="52" height="52" viewBox="0 0 52 52">
                <circle cx="26" cy="26" r="14" fill="none" stroke="rgba(167,139,250,0.12)" stroke-width="2"/>
                <circle cx="26" cy="26" r="14" fill="none" stroke="#A78BFA" stroke-width="2"
                    stroke-dasharray="88" stroke-dashoffset="66" stroke-linecap="round"/>
            </svg>
            <div class="spinner-dot"></div>
        </div>
        <p id="preloader-msg">Please wait...</p>
        <small id="preloader-sub"></small>
    </div>
</div>
<!-- ========================================================== -->
    <div class="auth-container">
        <div class="auth-card">
            @RenderBody()
        </div>
    </div>
    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/lib/kendo/kendo.all.min.js"></script>
     <!-- ===================== PRELOADER HELPER FUNCTIONS ===================== -->
    <script>
        // Call this to show the preloader with a custom message
        function showPreloader(msg, subMsg) {
            $("#preloader-msg").text(msg || "Please wait...");
            $("#preloader-sub").text(subMsg || "");
            $("#preloader").addClass("show");
        }

        // Call this to hide the preloader
        function hidePreloader() {
            $("#preloader").removeClass("show");
        }
    </script>
    <!-- ====================================================================== -->


    @RenderSection("Scripts",required:false)

</body>

</html>