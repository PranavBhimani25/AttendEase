<!-- ─── TRUSTED BY STRIP ─── -->
<div class="trust-strip">
    <div class="lp-container">
        <span class="trust-label">Trusted by teams using</span>
        <div class="trust-pills">
            <div class="trust-pill"><i class="fa fa-database"></i> PostgreSQL</div>
            <div class="trust-pill"><i class="fa fa-search"></i> Elasticsearch</div>
            <div class="trust-pill"><i class="fa fa-cloud"></i> Cloudinary</div>
            <div class="trust-pill"><i class="fa fa-envelope"></i> SMTP Mail</div>
            <div class="trust-pill"><i class="fa fa-bolt"></i> Redis Cache</div>
            <div class="trust-pill"><i class="fa fa-arrows-rotate"></i> RabbitMQ</div>
        </div>
    </div>
</div>

<!-- ─── FEATURES ─── -->
<section class="lp-section" id="features">
    <div class="lp-container">
        <div class="sec-head">
            <div class="sec-label"><span></span> Features</div>
            <h2 class="sec-title">Everything your team needs,<br>nothing it doesn't</h2>
            <p class="sec-sub">Built for modern workplaces — office, remote, or field.</p>
        </div>
        <div class="features-grid">
            <div class="feat-card fade-up">
                <div class="feat-icon" style="background:rgba(99,102,241,.12);color:#6366F1">
                    <i class="fa fa-clock"></i>
                </div>
                <h3 class="feat-title">Attendance Tracking</h3>
                <p class="feat-desc">Precision clock-in / clock-out with timestamps. Real-time status for every employee on one screen.</p>
                <div class="feat-pill"><span class="pill-dot green"></span>Live updates</div>
            </div>
            <div class="feat-card fade-up" style="animation-delay:.08s">
                <div class="feat-icon" style="background:rgba(139,92,246,.12);color:#8B5CF6">
                    <i class="fa fa-chart-pie"></i>
                </div>
                <h3 class="feat-title">Admin Dashboard</h3>
                <p class="feat-desc">At-a-glance KPIs, attendance trends, downloadable reports, and full employee oversight.</p>
                <div class="feat-pill"><span class="pill-dot purple"></span>Full analytics</div>
            </div>
            <div class="feat-card fade-up" style="animation-delay:.16s">
                <div class="feat-icon" style="background:rgba(236,72,153,.1);color:#EC4899">
                    <i class="fa fa-user-circle"></i>
                </div>
                <h3 class="feat-title">Employee Profiles</h3>
                <p class="feat-desc">Detailed profiles with photo, attendance history, work patterns, and performance stats.</p>
                <div class="feat-pill"><span class="pill-dot pink"></span>Profile photos</div>
            </div>
            <div class="feat-card fade-up" style="animation-delay:.24s">
                <div class="feat-icon" style="background:rgba(6,182,212,.1);color:#06B6D4">
                    <i class="fa fa-list-check"></i>
                </div>
                <h3 class="feat-title">Task Tracking</h3>
                <p class="feat-desc">Log task type per session — Developing, Designing, or Research — attached to each attendance record.</p>
                <div class="feat-pill"><span class="pill-dot green"></span>3 task types</div>
            </div>
            <div class="feat-card fade-up" style="animation-delay:.32s">
                <div class="feat-icon" style="background:rgba(16,185,129,.1);color:#10B981">
                    <i class="fa fa-globe"></i>
                </div>
                <h3 class="feat-title">Work Type Support</h3>
                <p class="feat-desc">Office, Remote, and Field — flexible modes for today's hybrid-first workforce with full reporting per type.</p>
                <div class="feat-pill"><span class="pill-dot purple"></span>Hybrid ready</div>
            </div>
            <div class="feat-card fade-up" style="animation-delay:.4s">
                <div class="feat-icon" style="background:rgba(245,158,11,.1);color:#F59E0B">
                    <i class="fa fa-file-pdf"></i>
                </div>
                <h3 class="feat-title">PDF Reports</h3>
                <p class="feat-desc">Generate and email monthly attendance PDFs with one click. Admins can send reports directly to employees.</p>
                <div class="feat-pill"><span class="pill-dot pink"></span>Email delivery</div>
            </div>
        </div>
    </div>
</section>

<!-- ─── HOW IT WORKS ─── -->
<section class="lp-section lp-how" id="how">
    <div class="lp-container">
        <div class="sec-head text-center">
            <div class="sec-label justify-center"><span></span> How It Works</div>
            <h2 class="sec-title">Up and running in minutes</h2>
            <p class="sec-sub mx-auto">Three simple steps from zero to a fully tracked, analytics-ready team.</p>
        </div>
        <div class="steps-row">
            <div class="step-card fade-up">
                <div class="step-num">
                    <div class="step-circle">
                        <i class="fa fa-user-plus"></i>
                    </div>
                    <div class="step-line"></div>
                </div>
                <h3 class="step-title">1. Register</h3>
                <p class="step-desc">Create your account, upload your profile photo, and set preferences. An admin activates your account — you're in.</p>
                <a href="/Auth/Register" class="step-link">Create account <i class="fa fa-arrow-right"></i></a>
            </div>
            <div class="step-card fade-up" style="animation-delay:.1s">
                <div class="step-num">
                    <div class="step-circle" style="background:linear-gradient(135deg,#8B5CF6,#EC4899)">
                        <i class="fa fa-fingerprint"></i>
                    </div>
                    <div class="step-line"></div>
                </div>
                <h3 class="step-title">2. Login &amp; Mark Attendance</h3>
                <p class="step-desc">Log in daily, choose your work type and task, then clock in. Clock out when your shift ends — that's it.</p>
                <a href="/Auth/Login" class="step-link">Login now <i class="fa fa-arrow-right"></i></a>
            </div>
            <div class="step-card fade-up" style="animation-delay:.2s">
                <div class="step-num">
                    <div class="step-circle" style="background:linear-gradient(135deg,#EC4899,#F97316)">
                        <i class="fa fa-chart-line"></i>
                    </div>
                </div>
                <h3 class="step-title">3. View Reports</h3>
                <p class="step-desc">Access monthly summaries, weekly trends, and export PDF reports. Admins get full visibility; employees see their own.</p>
                <a href="/Auth/Login" class="step-link">See demo <i class="fa fa-arrow-right"></i></a>
            </div>
        </div>
    </div>
</section>

