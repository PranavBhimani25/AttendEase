}
.hero-blob.b1 { width: 500px; height: 500px; background: #A78BFA; top: -120px; right: -100px; }
.hero-blob.b2 { width: 380px; height: 380px; background: #F472B6; bottom: -100px; left: -80px; animation-delay: 2s; animation-direction: alternate-reverse; }
.hero-blob.b3 { width: 300px; height: 300px; background: #6EE7B7; top: 50%; left: 40%; opacity: .1; animation-delay: 4s; }
@@keyframes blobFloat {
    from { transform: translate(0,0) scale(1); }
    to   { transform: translate(20px,-20px) scale(1.05); }
}

.hero-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center; position: relative; z-index: 1; }

/* Hero badge */
.hero-badge {
    display: inline-flex; align-items: center; gap: 8px;
    background: rgba(255,255,255,.13); backdrop-filter: blur(10px);
    border: 1px solid rgba(255,255,255,.22);
