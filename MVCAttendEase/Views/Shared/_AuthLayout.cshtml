<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AttendEase</title>

    <!-- Google Fonts: Poppins -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <!-- Font Awesome Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

    <!-- Kendo UI Nordic Theme -->
    <link rel="stylesheet" href="~/lib/kendo/bootstrap-nordic.css" />

    <style>
        /* ─── FOUNDATION ─── */
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --primary:   #6366F1;
            --secondary: #8B5CF6;
            --accent:    #EC4899;
            --success:   #6EE7B7;
            --text-dark: #0F172A;
            --text-mid:  #475569;
            --text-soft: #94A3B8;
            --border:    #E2E8F0;
            --surface:   #F8FAFC;
        }

        html, body {
            height: 100%;
            font-family: 'Poppins', sans-serif;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
        }

        /* ─── KENDO GLOBAL OVERRIDES ─── */

        /* Remove Kendo's default fieldset wrapper look */
        .k-form fieldset { border: none; padding: 0; margin: 0; }
        .k-form legend   { display: none; }

        /* Notification polish */
        .k-notification-group { z-index: 9999 !important; }
        .k-notification        { border-radius: 12px !important; font-family: 'Poppins', sans-serif !important; font-size: 13px !important; }
        .k-notification-success { background: #ECFDF5 !important; border-color: #A7F3D0 !important; color: #065F46 !important; }
        .k-notification-error   { background: #FEF2F2 !important; border-color: #FECACA !important; color: #991B1B !important; }

        /* Remove Kendo's bold form labels default */
        .k-form .k-form-label { font-weight: 600 !important; }

        /* Ensure inputs don't have Kendo's default box-shadow on focus (we handle it) */
        .k-input:focus, .k-textbox:focus { outline: none !important; }

        /* ─── CUSTOM SCROLLBAR ─── */
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #CBD5E1; border-radius: 10px; }
        ::-webkit-scrollbar-thumb:hover { background: #94A3B8; }
    </style>
</head>

<body>
    @RenderBody()

    <!-- jQuery -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <!-- Bootstrap JS (optional) -->
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <!-- Kendo All -->
    <script src="~/lib/kendo/kendo.all.min.js"></script>
     <!-- ===================== PRELOADER HELPER FUNCTIONS ===================== -->
    <script>
        // Call this to show the preloader with a custom message
        function showPreloader(msg, subMsg) {
            $("#preloader-msg").text(msg || "Please wait...");
            $("#preloader-sub").text(subMsg || "");
            $("#preloader").addClass("show");
        }

        // Call this to hide the preloader
        function hidePreloader() {
            $("#preloader").removeClass("show");
        }
    </script>
    <!-- ====================================================================== -->

    @RenderSection("Scripts", required: false)
</body>
</html>
