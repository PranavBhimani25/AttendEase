}
.sec-sub { color: var(--text-soft); font-size: 15px; line-height: 1.7; }
.mx-auto { margin: 0 auto; max-width: 500px; }

/* ── FEATURES GRID ── matches card style from auth ── */
.features-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; }
.feat-card {
    background: #fff; border: 1px solid var(--border);
    border-radius: 20px; padding: 28px 24px;
    box-shadow: 0 2px 12px rgba(0,0,0,.04);
    transition: all .3s cubic-bezier(.4,0,.2,1);
    position: relative; overflow: hidden;
}
.feat-card::before {
    content: ''; position: absolute; inset: 0; border-radius: 20px;
    background: linear-gradient(135deg, rgba(99,102,241,.04), transparent);
    opacity: 0; transition: .3s;
}
.feat-card:hover {
    transform: translateY(-5px);
    border-color: rgba(99,102,241,.25);
    box-shadow: 0 16px 50px rgba(99,102,241,.14);
}
.feat-card:hover::before { opacity: 1; }
.feat-icon {
    width: 46px; height: 46px; border-radius: 13px;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.1rem; margin-bottom: 18px;
